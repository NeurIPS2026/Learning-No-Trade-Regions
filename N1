# Diagnostics
# ============================================================

def wedge_diagnostics(pmp: Dict, cfg: Config1D) -> Dict:
    R = pmp["R"]
    u = pmp["u_pmp"]
    pmp_region = pmp["pmp_region"]
    wedge_region = pmp["wedge_region"]

    valid = np.isfinite(R) & np.isfinite(u)

    sign_mismatch = (
        float(np.mean(pmp_region[valid] != wedge_region[valid]))
        if np.any(valid)
        else np.nan
    )

    hold_by_wedge = (R >= 1.0 - cfg.alpha) & (R <= 1.0)
    hold_by_u = np.abs(u) <= cfg.u_tol_region

    wedge_hold_agreement = (
        float(np.mean(hold_by_wedge[valid] == hold_by_u[valid]))
        if np.any(valid)
        else np.nan
    )

    violation_distance = np.zeros_like(R, dtype=np.float64)

    below = hold_by_u & (R < 1.0 - cfg.alpha)
    above = hold_by_u & (R > 1.0)
    violation_distance[below] = (1.0 - cfg.alpha) - R[below]
    violation_distance[above] = R[above] - 1.0

    inside = hold_by_wedge
    trade = ~hold_by_u
    violation_distance[trade & inside] = np.minimum(
        R[trade & inside] - (1.0 - cfg.alpha),
        1.0 - R[trade & inside],
    )

    mean_violation_distance = (
        float(np.nanmean(violation_distance[valid]))
        if np.any(valid)
        else np.nan
    )
    max_violation_distance = (
        float(np.nanmax(violation_distance[valid]))
        if np.any(valid)
        else np.nan
    )

    lo, hi, width = extract_hold_interval(pmp["p"], pmp_region)

    return dict(
        sign_mismatch_rate=sign_mismatch,
        wedge_hold_agreement=wedge_hold_agreement,
        mean_violation_distance=mean_violation_distance,
        max_violation_distance=max_violation_distance,
        pmp_hold_lower=lo,
        pmp_hold_upper=hi,
        pmp_hold_width=width,
        pmp_buy_frac=float(np.mean(pmp_region[valid] == 1)) if np.any(valid) else np.nan,
        pmp_hold_frac=float(np.mean(pmp_region[valid] == 0)) if np.any(valid) else np.nan,
        pmp_sell_frac=float(np.mean(pmp_region[valid] == -1)) if np.any(valid) else np.nan,
    )


def benchmark_comparison(stage1: Dict, pmp: Dict, bench: Dict, cfg: Config1D) -> Dict:
    p_common = pmp["p"]

    # Nearest-neighbor benchmark region on p_common.
    idx = np.searchsorted(bench["p"], p_common)
    idx = np.clip(idx, 1, len(bench["p"]) - 1)

    left = bench["p"][idx - 1]
    right = bench["p"][idx]
    nearest = np.where(np.abs(p_common - left) <= np.abs(p_common - right), idx - 1, idx)

    bench_region = bench["bench_region"][nearest]

    stage1_region = stage1["stage1_region"]
    pmp_region = pmp["pmp_region"]

    m_stage1 = classification_metrics(stage1_region, bench_region)
    m_pmp = classification_metrics(pmp_region, bench_region)

    b_lo, b_hi, b_w = extract_hold_interval(p_common, bench_region)
    s_lo, s_hi, s_w = extract_hold_interval(p_common, stage1_region)
    p_lo, p_hi, p_w = extract_hold_interval(p_common, pmp_region)

    def boundary_mae(lo, hi):
        if np.isnan(lo) or np.isnan(hi) or np.isnan(b_lo) or np.isnan(b_hi):
            return np.nan
        return float(0.5 * (abs(lo - b_lo) + abs(hi - b_hi)))

    return dict(
        stage1_acc=m_stage1["acc"],
        stage1_hold_iou=m_stage1["hold_iou"],
        stage1_hold_acc=m_stage1["hold_acc"],
        stage1_buy_acc=m_stage1["buy_acc"],
        stage1_sell_acc=m_stage1["sell_acc"],

        pmp_acc=m_pmp["acc"],
        pmp_hold_iou=m_pmp["hold_iou"],
        pmp_hold_acc=m_pmp["hold_acc"],
        pmp_buy_acc=m_pmp["buy_acc"],
        pmp_sell_acc=m_pmp["sell_acc"],

        bench_hold_lower=b_lo,
        bench_hold_upper=b_hi,
        bench_hold_width=b_w,

        stage1_hold_lower=s_lo,
        stage1_hold_upper=s_hi,
        stage1_hold_width=s_w,

        pmp_hold_lower=p_lo,
        pmp_hold_upper=p_hi,
        pmp_hold_width=p_w,

        stage1_boundary_mae=boundary_mae(s_lo, s_hi),
        pmp_boundary_mae=boundary_mae(p_lo, p_hi),
    )


