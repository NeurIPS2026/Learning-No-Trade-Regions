def run_single_experiment(cfg_run: Config1D, outdir: str) -> Dict:
    set_seed(cfg_run.seed)
    device = choose_device(cfg_run.device)

    ensure_dir(outdir)
    ensure_dir(os.path.join(outdir, "figures"))
    ensure_dir(os.path.join(outdir, "csv"))

    save_json(asdict(cfg_run), os.path.join(outdir, "config.json"))

    print("=" * 90)
    print(
        f"[RUN] alpha={cfg_run.alpha:.4f}, T={cfg_run.T:.2f}, eps={cfg_run.eps:.5f}, "
        f"n_steps={cfg_run.n_steps}, dt={cfg_run.dt:.5f}"
    )
    print(f"      device={device}, outdir={outdir}")
    print("=" * 90)

    # 1. Train Stage1 under this same eps.
    print("[1/4] Train Stage1 policy")
    policy, train_hist = train_stage1_policy(cfg_run, device)
    pd.DataFrame(train_hist).to_csv(os.path.join(outdir, "csv", "training_curve.csv"), index=False)

    # 2. Solve same-eps DP benchmark.
    print("[2/4] Solve 1D DP benchmark")
    t_values = [float(frac * cfg_run.T) for frac in cfg_run.t_frac_sweep]
    dp = solve_1d_dp_benchmark(cfg_run, t_values=t_values)

    # 3. Evaluate Stage1 and PMP over t snapshots.
    print("[3/4] Evaluate wedge diagnostics and benchmark errors")

    p_grid = np.linspace(cfg_run.p_min, cfg_run.p_max, cfg_run.p_grid_size)

    rows_wedge = []
    rows_comp = []

    for t_frac in cfg_run.t_frac_sweep:
        t_value = float(t_frac * cfg_run.T)
        bench_snap = nearest_benchmark_snapshot(dp, t_value)

        stage1 = stage1_action_on_grid(policy, p_grid, t_value, cfg_run, device)
        pmp = pmp_project_on_grid(policy, p_grid, t_value, cfg_run, device)

        wdiag = wedge_diagnostics(pmp, cfg_run)
        cdiag = benchmark_comparison(stage1, pmp, bench_snap, cfg_run)

        row_base = dict(
            alpha=cfg_run.alpha,
            T=cfg_run.T,
            eps=cfg_run.eps,
            n_steps=cfg_run.n_steps,
            dt=cfg_run.dt,
            t_frac=t_frac,
            t=t_value,
            merton_fraction=merton_fraction(cfg_run),
        )

        rows_wedge.append({**row_base, **wdiag})
        rows_comp.append({**row_base, **cdiag})

        tag = (
            f"alpha{cfg_run.alpha:.3f}_T{cfg_run.T:.1f}_eps{cfg_run.eps:.4f}_tfrac{t_frac:.2f}"
            .replace(".", "p")
        )

        plot_wedge_ratio(
            os.path.join(outdir, "figures", f"wedge_ratio_{tag}.png"),
            pmp,
            cfg_run,
            title=fr"$\alpha={cfg_run.alpha:.3f}$, $T={cfg_run.T:.1f}$, "
                  fr"$\varepsilon={cfg_run.eps:.4f}$, $t/T={t_frac:.2f}$",
        )

        plot_region_comparison(
            os.path.join(outdir, "figures", f"region_compare_{tag}.png"),
            stage1,
            pmp,
            bench_snap,
            cfg_run,
            title=fr"Benchmark vs Stage1 vs PGDPO, $t/T={t_frac:.2f}$",
        )

    wedge_df = pd.DataFrame(rows_wedge)
    comp_df = pd.DataFrame(rows_comp)

    wedge_df.to_csv(os.path.join(outdir, "csv", "wedge_validation.csv"), index=False)
    comp_df.to_csv(os.path.join(outdir, "csv", "benchmark_comparison.csv"), index=False)

    print("[4/4] Save local summaries")
    plot_boundary_error_summary(
        os.path.join(outdir, "figures", "boundary_error_vs_epsilon_local.png"),
        comp_df,
    )

    return dict(
        cfg=cfg_run,
        policy=policy,
        dp=dp,
        wedge_df=wedge_df,
        comp_df=comp_df,
    )


