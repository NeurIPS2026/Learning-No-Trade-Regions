# ============================================================
# Config
# ============================================================

@dataclass
class Config1D:
    # Market / horizon
    T: float = 1.0
    n_steps: int = 20
    r: float = 0.02
    mu: float = 0.08
    sigma: float = 0.20
    gamma: float = 3.0
    alpha: float = 0.03

    # Single epsilon used everywhere:
    #   1. dynamics: -0.5 * eps * L * u^2 dt
    #   2. PMP projection denominator: eps * lambda_x
    #   3. DP benchmark transition
    eps: float = 0.01
    u_max: float = 10.0

    # Stage1 training
    hidden: int = 128
    depth: int = 3
    batch_size: int = 256
    n_train_steps: int = 1200
    lr: float = 1e-3
    print_every: int = 200

    # Initial state sampling
    logw_low: float = math.log(0.8)
    logw_high: float = math.log(1.2)
    p_init_low: float = 0.02
    p_init_high: float = 0.85

    # BPTT / PMP projection
    inner_mc_paths: int = 256
    eval_chunk_size: int = 64
    lambda_floor: float = 1e-10
    use_common_random_numbers: bool = True
    use_antithetic: bool = True

    # 1D analysis grid in gross risky fraction p=Y/(X+Y)
    p_min: float = 0.00
    p_max: float = 0.95
    p_grid_size: int = 301
    u_tol_region: float = 1e-3

    # 1D DP benchmark
    dp_grid_size: int = 401
    dp_action_size: int = 401
    dp_gh_nodes: int = 9
    dp_region_tol: float = 1e-3

    # Sweeps
    alpha_sweep: Tuple[float, ...] = (0.01, 0.03, 0.05)
    T_sweep: Tuple[float, ...] = (1.0, 5.0, 10.0)
    eps_sweep: Tuple[float, ...] = (0.005, 0.01, 0.02, 0.05)
    t_frac_sweep: Tuple[float, ...] = (0.0, 0.5, 0.9)

    # Misc
    seed: int = 800
    device: str = "auto"
    outdir: str = "paper_N1_wedge_benchmark_single_eps"

    @property
    def dt(self) -> float:
        return self.T / self.n_steps


# ============================================================
# Utilities
# ============================================================

def set_seed(seed: int) -> None:
    random.seed(seed)
    np.random.seed(seed)
    torch.manual_seed(seed)
    if torch.cuda.is_available():
        torch.cuda.manual_seed_all(seed)


def choose_device(device_arg: str) -> torch.device:
    if device_arg == "auto":
        return torch.device("cuda" if torch.cuda.is_available() else "cpu")
    if device_arg.startswith("cuda") and not torch.cuda.is_available():
        raise RuntimeError("CUDA requested but not available.")
    return torch.device(device_arg)


def ensure_dir(path: str) -> None:
    os.makedirs(path, exist_ok=True)


def save_json(obj: Dict, path: str) -> None:
    def conv(x):
        if isinstance(x, (np.integer, np.floating)):
            return x.item()
        if isinstance(x, np.ndarray):
            return x.tolist()
        if isinstance(x, tuple):
            return list(x)
        return x

    with open(path, "w", encoding="utf-8") as f:
        json.dump({k: conv(v) for k, v in obj.items()}, f, indent=2)


def crra_utility(x: torch.Tensor, gamma: float) -> torch.Tensor:
    x = torch.clamp(x, min=1e-12)
    if abs(gamma - 1.0) < 1e-12:
        return torch.log(x)
    return (x.pow(1.0 - gamma) - 1.0) / (1.0 - gamma)


def liquidation_wealth(x: torch.Tensor, y: torch.Tensor, alpha: float) -> torch.Tensor:
    return x + (1.0 - alpha) * y


def gross_wealth(x: torch.Tensor, y: torch.Tensor) -> torch.Tensor:
    return x + y


def merton_fraction(cfg: Config1D) -> float:
    return float((cfg.mu - cfg.r) / (cfg.gamma * cfg.sigma**2))


def region_from_action(u: np.ndarray, tol: float) -> np.ndarray:
    """
    +1 = buy, 0 = hold, -1 = sell.
    """
    out = np.zeros_like(u, dtype=np.int64)
    out[u > tol] = 1
    out[u < -tol] = -1
    return out


def classification_metrics(pred: np.ndarray, ref: np.ndarray, valid: Optional[np.ndarray] = None) -> Dict:
    if valid is None:
        valid = np.isfinite(pred) & np.isfinite(ref)

    valid = valid.astype(bool)
    pred = pred[valid].astype(np.int64)
    ref = ref[valid].astype(np.int64)

    if pred.size == 0:
        return dict(
            acc=np.nan,
            hold_acc=np.nan,
            buy_acc=np.nan,
            sell_acc=np.nan,
            hold_iou=np.nan,
        )

    acc = float(np.mean(pred == ref))

    def class_acc(c):
        mask = ref == c
        if not np.any(mask):
            return np.nan
        return float(np.mean(pred[mask] == c))

    pred_hold = pred == 0
    ref_hold = ref == 0
    inter = np.sum(pred_hold & ref_hold)
    union = np.sum(pred_hold | ref_hold)
    hold_iou = float(inter / union) if union > 0 else np.nan

    return dict(
        acc=acc,
        hold_acc=class_acc(0),
        buy_acc=class_acc(1),
        sell_acc=class_acc(-1),
        hold_iou=hold_iou,
    )


def extract_hold_interval(p_grid: np.ndarray, region: np.ndarray) -> Tuple[float, float, float]:
    hold = region == 0
    if not np.any(hold):
        return np.nan, np.nan, 0.0

    idx = np.where(hold)[0]
    comps = []
    s = idx[0]
    prev = idx[0]

    for k in idx[1:]:
        if k == prev + 1:
            prev = k
        else:
            comps.append((s, prev))
            s = prev = k
    comps.append((s, prev))

    best = max(comps, key=lambda ab: ab[1] - ab[0])
    lo = float(p_grid[best[0]])
    hi = float(p_grid[best[1]])
    return lo, hi, hi - lo


# ============================================================
# Policy Network
# ============================================================

class PolicyNet1D(nn.Module):
    def __init__(self, hidden: int = 96, depth: int = 3):
        super().__init__()
        layers = []
        d = 3  # t/T, logW, p=Y/W

        for _ in range(depth):
            layers.append(nn.Linear(d, hidden))
            layers.append(nn.Tanh())
            d = hidden

        layers.append(nn.Linear(d, 1))
        self.net = nn.Sequential(*layers)

    def forward(self, z: torch.Tensor) -> torch.Tensor:
        return self.net(z).squeeze(-1)


def state_features(t_frac: torch.Tensor, x: torch.Tensor, y: torch.Tensor) -> torch.Tensor:
    W = torch.clamp(gross_wealth(x, y), min=1e-12)
    p = y / W
    return torch.stack([t_frac, torch.log(W), p], dim=-1)


def sample_initial_states(cfg: Config1D, batch: int, device: torch.device) -> Tuple[torch.Tensor, torch.Tensor]:
    logW = torch.empty(batch, device=device).uniform_(cfg.logw_low, cfg.logw_high)
    W = torch.exp(logW)

    p = torch.empty(batch, device=device).uniform_(cfg.p_init_low, cfg.p_init_high)
    y = p * W
    x = W - y

    return x, y


# ============================================================
# Dynamics with single eps
# ============================================================

def is_feasible_rate(x: torch.Tensor, y: torch.Tensor, u: torch.Tensor, cfg: Config1D) -> torch.Tensor:
    L = liquidation_wealth(x, y, cfg.alpha)
    dt = cfg.dt

    buy = torch.relu(u)
    sell = torch.relu(-u)

    x_trade = (
        x
        - L * buy * dt
        + (1.0 - cfg.alpha) * L * sell * dt
        - 0.5 * cfg.eps * L * (u ** 2) * dt
    )
    y_trade = y + L * u * dt

    L_trade = liquidation_wealth(x_trade, y_trade, cfg.alpha)
    return (y_trade >= -1e-12) & (L_trade > 1e-10)


def project_rate(u_raw: torch.Tensor, x: torch.Tensor, y: torch.Tensor, cfg: Config1D) -> torch.Tensor:
    u = torch.clamp(u_raw, min=-cfg.u_max, max=cfg.u_max)

    L = torch.clamp(liquidation_wealth(x, y, cfg.alpha), min=1e-12)

    # No overselling within one step.
    lower = -y / (L * cfg.dt)
    u = torch.maximum(u, lower)
    u = torch.clamp(u, min=-cfg.u_max, max=cfg.u_max)

    ok = is_feasible_rate(x, y, u, cfg)
    if bool(ok.all()):
        return u

    out = u.clone()
    bad = torch.where(~ok)[0]
    if bad.numel() == 0:
        return out

    u_bad = u[bad]
    x_bad = x[bad]
    y_bad = y[bad]

    lo = torch.zeros_like(u_bad)
    hi = torch.ones_like(u_bad)

    for _ in range(30):
        mid = 0.5 * (lo + hi)
        cand = u_bad * mid
        ok_mid = is_feasible_rate(x_bad, y_bad, cand, cfg)
        lo = torch.where(ok_mid, mid, lo)
        hi = torch.where(ok_mid, hi, mid)

    out[bad] = u_bad * lo
    return out


def policy_action(policy: PolicyNet1D, t_frac: torch.Tensor, x: torch.Tensor, y: torch.Tensor, cfg: Config1D) -> torch.Tensor:
    raw = policy(state_features(t_frac, x, y))
    u = cfg.u_max * torch.tanh(raw)
    return project_rate(u, x, y, cfg)


def step_dynamics(
    x: torch.Tensor,
    y: torch.Tensor,
    u: torch.Tensor,
    z: torch.Tensor,
    cfg: Config1D,
) -> Tuple[torch.Tensor, torch.Tensor]:

    L = liquidation_wealth(x, y, cfg.alpha)
    u = project_rate(u, x, y, cfg)
    dt = cfg.dt

    buy = torch.relu(u)
    sell = torch.relu(-u)

    x_trade = (
        x
        - L * buy * dt
        + (1.0 - cfg.alpha) * L * sell * dt
        - 0.5 * cfg.eps * L * (u ** 2) * dt
    )
    y_trade = torch.clamp(y + L * u * dt, min=0.0)

    x_next = x_trade * math.exp(cfg.r * dt)
    y_next = y_trade * torch.exp(
        (cfg.mu - 0.5 * cfg.sigma**2) * dt
        + cfg.sigma * math.sqrt(dt) * z
    )

    return x_next, y_next


def rollout_policy(
    policy: PolicyNet1D,
    x0: torch.Tensor,
    y0: torch.Tensor,
    start_step: int,
    cfg: Config1D,
    noise_bank: Optional[torch.Tensor] = None,
) -> Tuple[torch.Tensor, torch.Tensor]:

    x, y = x0, y0
    batch = x.shape[0]
    device = x.device

    for step in range(start_step, cfg.n_steps):
        t_frac = torch.full((batch,), step / cfg.n_steps, device=device)
        u = policy_action(policy, t_frac, x, y, cfg)

        if noise_bank is None:
            z = torch.randn(batch, device=device)
        else:
            z = noise_bank[step - start_step, :batch]

        x, y = step_dynamics(x, y, u, z, cfg)

    return x, y


# ============================================================
# Noise banks
# ============================================================

def base_noise_count(m: int, antithetic: bool) -> Tuple[int, int]:
    if not antithetic:
        return int(m), int(m)
    half = int(math.ceil(m / 2))
    return half, 2 * half


def build_inner_noise_bank(
    start_step: int,
    batch_states: int,
    cfg: Config1D,
    device: torch.device,
    m: Optional[int] = None,
):
    remaining = cfg.n_steps - start_step
    if remaining <= 0:
        return None

    m_eff = cfg.inner_mc_paths if m is None else int(m)
    base, total = base_noise_count(m_eff, cfg.use_antithetic)

    gen = torch.Generator(device="cpu")
    gen.manual_seed(cfg.seed + 1000 * (start_step + 1))

    z_base = torch.randn((remaining, base, batch_states), generator=gen, device="cpu").to(device)

    if cfg.use_antithetic:
        z = torch.cat([z_base, -z_base], dim=1)[:, :total, :]
    else:
        z = z_base

    return z.permute(0, 2, 1).reshape(remaining, batch_states * total)


# ============================================================
# Stage1 training
# ============================================================

def train_stage1_policy(cfg: Config1D, device: torch.device) -> Tuple[PolicyNet1D, Dict]:
    policy = PolicyNet1D(hidden=cfg.hidden, depth=cfg.depth).to(device)
    opt = optim.Adam(policy.parameters(), lr=cfg.lr)

    hist = {"step": [], "EU": []}

    for step in range(cfg.n_train_steps + 1):
        x0, y0 = sample_initial_states(cfg, cfg.batch_size, device)
        xT, yT = rollout_policy(policy, x0, y0, 0, cfg)

        LT = liquidation_wealth(xT, yT, cfg.alpha)
        obj = crra_utility(LT, cfg.gamma).mean()
        loss = -obj

        opt.zero_grad(set_to_none=True)
        loss.backward()
        opt.step()

        if step % cfg.print_every == 0 or step == cfg.n_train_steps:
            val = float(obj.detach().cpu().item())
            hist["step"].append(step)
            hist["EU"].append(val)
            print(f"    [Stage1] step={step:5d}  E[U(L_T)]={val:.8f}")

    return policy, hist


# ============================================================
# Stage1 action on p-grid
# ============================================================

@torch.no_grad()
def stage1_action_on_grid(
    policy: PolicyNet1D,
    p_grid: np.ndarray,
    t_value: float,
    cfg: Config1D,
    device: torch.device,
) -> Dict:

    policy.eval()

    p = torch.tensor(p_grid, dtype=torch.float32, device=device)
    x = 1.0 - p
    y = p

    t_frac = torch.full_like(p, t_value / cfg.T)
    u = policy_action(policy, t_frac, x, y, cfg)

    u_np = u.detach().cpu().numpy()
    region = region_from_action(u_np, cfg.u_tol_region)

    return dict(
        p=p_grid.copy(),
        t=t_value,
        u_stage1=u_np,
        stage1_region=region,
    )


# ============================================================
# PMP projection on p-grid with single eps
# ============================================================

def pmp_project_on_grid(
    policy: PolicyNet1D,
    p_grid: np.ndarray,
    t_value: float,
    cfg: Config1D,
    device: torch.device,
) -> Dict:

    policy.eval()

    start_step = int(round(t_value / cfg.dt))
    start_step = max(0, min(cfg.n_steps - 1, start_step))

    all_p, all_u, all_lx, all_ly, all_R = [], [], [], [], []

    p_tensor_all = torch.tensor(p_grid, dtype=torch.float32, device=device)

    for start in range(0, len(p_grid), cfg.eval_chunk_size):
        p_batch = p_tensor_all[start:start + cfg.eval_chunk_size]
        b = p_batch.numel()

        # W=1 slice: x=1-p, y=p.
        x0 = (1.0 - p_batch).clone().detach().requires_grad_(True)
        y0 = p_batch.clone().detach().requires_grad_(True)

        m_eff = int(cfg.inner_mc_paths)
        _, total = base_noise_count(m_eff, cfg.use_antithetic)
        m_paths = total if cfg.use_antithetic else m_eff

        x_rep = (
            x0.view(1, b)
            .repeat(m_paths, 1)
            .reshape(-1)
            .clone()
            .detach()
            .requires_grad_(True)
        )
        y_rep = (
            y0.view(1, b)
            .repeat(m_paths, 1)
            .reshape(-1)
            .clone()
            .detach()
            .requires_grad_(True)
        )

        if cfg.use_common_random_numbers:
            noise = build_inner_noise_bank(start_step, b, cfg, device, m=m_eff)
        else:
            noise = None

        xT, yT = rollout_policy(policy, x_rep, y_rep, start_step, cfg, noise_bank=noise)
        payoff = crra_utility(liquidation_wealth(xT, yT, cfg.alpha), cfg.gamma)

        grad_x, grad_y = torch.autograd.grad(
            payoff.sum(),
            [x_rep, y_rep],
            create_graph=False,
        )

        lam_x = grad_x.view(m_paths, b).mean(dim=0)
        lam_y = grad_y.view(m_paths, b).mean(dim=0)

        lam_x_safe = torch.clamp(lam_x, min=cfg.lambda_floor)
        R = lam_y / lam_x_safe

        denom = torch.clamp(cfg.eps * lam_x_safe, min=cfg.lambda_floor)

        u_buy = torch.relu((lam_y - lam_x) / denom)
        u_sell = torch.relu(((1.0 - cfg.alpha) * lam_x - lam_y) / denom)
        u_pmp = u_buy - u_sell

        # Feasibility projection.
        x_base = (1.0 - p_batch).detach()
        y_base = p_batch.detach()
        u_pmp = project_rate(u_pmp.detach(), x_base, y_base, cfg)

        all_p.append(p_batch.detach().cpu().numpy())
        all_u.append(u_pmp.detach().cpu().numpy())
        all_lx.append(lam_x.detach().cpu().numpy())
        all_ly.append(lam_y.detach().cpu().numpy())
        all_R.append(R.detach().cpu().numpy())

    p = np.concatenate(all_p)
    u = np.concatenate(all_u)
    lam_x = np.concatenate(all_lx)
    lam_y = np.concatenate(all_ly)
    R = np.concatenate(all_R)

    pmp_region = region_from_action(u, cfg.u_tol_region)

    wedge_region = np.zeros_like(pmp_region)
    wedge_region[R > 1.0] = 1
    wedge_region[R < 1.0 - cfg.alpha] = -1

    margin = np.minimum(np.abs(R - (1.0 - cfg.alpha)), np.abs(R - 1.0))

    return dict(
        p=p,
        t=t_value,
        eps=cfg.eps,
        u_pmp=u,
        lam_x=lam_x,
        lam_y=lam_y,
        R=R,
        pmp_region=pmp_region,
        wedge_region=wedge_region,
        margin=margin,
    )


# ============================================================
# 1D regularized trading-rate DP benchmark
# ============================================================

def solve_1d_dp_benchmark(cfg: Config1D, t_values: List[float]) -> Dict:
    """
    1D regularized trading-rate DP benchmark.

    This benchmark matches the same regularized dynamics used by Stage1
    and PMP projection:

        X_trade = X
                  - L u^+ dt
                  + (1-alpha)L u^- dt
                  - 0.5 eps L u^2 dt

        Y_trade = Y + L u dt

    State:
        p = Y / (X + Y)

    Action:
        trading rate u.
    """
    print("    [DP] solving 1D regularized trading-rate benchmark...")

    P = int(cfg.dp_grid_size)
    A = int(cfg.dp_action_size)

    p_grid = np.linspace(cfg.p_min, cfg.p_max, P)
    u_grid = np.linspace(-cfg.u_max, cfg.u_max, A)

    dt = cfg.dt
    alpha = cfg.alpha
    gamma = cfg.gamma
    eps = cfg.eps

    # Gauss-Hermite quadrature for Z ~ N(0, 1).
    gh_x, gh_w = np.polynomial.hermite.hermgauss(cfg.dp_gh_nodes)
    z_nodes = np.sqrt(2.0) * gh_x
    z_weights = gh_w / np.sqrt(np.pi)

    Rf = math.exp(cfg.r * dt)
    Rs_nodes = np.exp(
        (cfg.mu - 0.5 * cfg.sigma**2) * dt
        + cfg.sigma * math.sqrt(dt) * z_nodes
    )

    # Terminal condition on W=1:
    # L_T = X + (1-alpha)Y = W * (1-alpha p).
    liq_factor = np.maximum(1.0 - alpha * p_grid, 1e-12)

    if abs(gamma - 1.0) < 1e-12:
        V_next = np.log(liq_factor)
    else:
        V_next = liq_factor ** (1.0 - gamma) / (1.0 - gamma)

    target_steps = sorted(set([
        max(0, min(cfg.n_steps - 1, int(round(t / cfg.dt))))
        for t in t_values
    ]))

    snapshots = {}

    for k in range(cfg.n_steps - 1, -1, -1):
        V_cur = np.empty_like(p_grid)
        u_star = np.empty_like(p_grid)

        for ip, p in enumerate(p_grid):
            # W=1 slice.
            x = 1.0 - p
            y = p
            L = 1.0 - alpha * p

            u = u_grid

            buy = np.maximum(u, 0.0)
            sell = np.maximum(-u, 0.0)

            x_trade = (
                x
                - L * buy * dt
                + (1.0 - alpha) * L * sell * dt
                - 0.5 * eps * L * (u ** 2) * dt
            )
            y_trade = y + L * u * dt

            L_trade = x_trade + (1.0 - alpha) * y_trade

            valid = (
                (y_trade >= 0.0)
                & (L_trade > 1e-12)
                & np.isfinite(L_trade)
                & np.isfinite(x_trade)
                & np.isfinite(y_trade)
            )

            if not np.any(valid):
                V_cur[ip] = -1e30
                u_star[ip] = 0.0
                continue

            u_valid = u[valid]
            x_tr = x_trade[valid]
            y_tr = y_trade[valid]

            # Apply returns.
            x_next = x_tr[:, None] * Rf
            y_next = y_tr[:, None] * Rs_nodes[None, :]

            W_next = np.maximum(x_next + y_next, 1e-12)
            p_next = y_next / W_next
            p_next = np.clip(p_next, cfg.p_min, cfg.p_max)

            V_interp = np.interp(
                p_next.ravel(),
                p_grid,
                V_next,
            ).reshape(p_next.shape)

            if abs(gamma - 1.0) < 1e-12:
                vals = np.sum(
                    z_weights[None, :] * (np.log(W_next) + V_interp),
                    axis=1,
                )
            else:
                vals = np.sum(
                    z_weights[None, :]
                    * (W_next ** (1.0 - gamma))
                    * V_interp,
                    axis=1,
                )

            best = int(np.argmax(vals))
            V_cur[ip] = vals[best]
            u_star[ip] = u_valid[best]

        V_next = V_cur

        if k in target_steps:
            bench_region = region_from_action(u_star, cfg.dp_region_tol)

            snapshots[k] = dict(
                step=k,
                time=k * cfg.dt,
                p=p_grid.copy(),
                u_star=u_star.copy(),
                bench_region=bench_region.copy(),
                V=V_cur.copy(),
            )

    return dict(
