def plot_region_comparison(path: str, stage1: Dict, pmp: Dict, bench: Dict, cfg: Config1D, title: str = "") -> None:
    p = pmp["p"]

    idx = np.searchsorted(bench["p"], p)
    idx = np.clip(idx, 1, len(bench["p"]) - 1)

