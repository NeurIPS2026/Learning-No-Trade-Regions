def nearest_benchmark_snapshot(dp: Dict, t_value: float) -> Dict:
    snaps = dp["snapshots"]
    keys = sorted(snaps.keys())
    key = min(keys, key=lambda k: abs(snaps[k]["time"] - t_value))
    return snaps[key]


