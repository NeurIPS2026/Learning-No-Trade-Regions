# -----------------------------
def _nearest_region_on_common_grid(bench_snap, p_common):
    p_b = bench_snap["p"]
    r_b = bench_snap["bench_region"]

    idx = np.searchsorted(p_b, p_common)
    idx = np.clip(idx, 1, len(p_b) - 1)

    left = p_b[idx - 1]
    right = p_b[idx]
    nearest = np.where(np.abs(p_common - left) <= np.abs(p_common - right), idx - 1, idx)

    return r_b[nearest]


def _hold_interval(p, region):
    hold = region == 0
    if not np.any(hold):
        return np.nan, np.nan, 0.0

    idx = np.where(hold)[0]
    comps = []
    s = idx[0]
    prev = idx[0]

    for k in idx[1:]:
        if k == prev + 1:
            prev = k
        else:
            comps.append((s, prev))
            s = prev = k
    comps.append((s, prev))

    best = max(comps, key=lambda ab: ab[1] - ab[0])
    lo = float(p[best[0]])
    hi = float(p[best[1]])
    return lo, hi, hi - lo


def _boundary_mae(method_lo, method_hi, bench_lo, bench_hi):
    if np.any(np.isnan([method_lo, method_hi, bench_lo, bench_hi])):
        return np.nan
    return 0.5 * (abs(method_lo - bench_lo) + abs(method_hi - bench_hi))


