    if np.isclose(k[0], FIX_ALPHA) and np.isclose(k[1], FIX_T) and np.isclose(k[2], ref_eps)
]
if len(ref_key_candidates) == 0:
    raise RuntimeError("Reference eps run not found.")

ref_key = ref_key_candidates[0]
cfg_ref = run_results[ref_key]["cfg"]

cfg_bench0 = replace(cfg_ref, eps=0.0)

t_value = float(FIX_T_FRAC * cfg_bench0.T)

# Solve true eps=0 benchmark once
dp_bench0 = solve_1d_dp_benchmark(cfg_bench0, t_values=[t_value])
bench0_snap = nearest_benchmark_snapshot(dp_bench0, t_value)

# Common p-grid for all curves
p_grid = np.linspace(cfg_ref.p_min, cfg_ref.p_max, cfg_ref.p_grid_size)

bench0_region = _nearest_region_on_common_grid(bench0_snap, p_grid)
bench0_lo, bench0_hi, bench0_width = _hold_interval(p_grid, bench0_region)

print(f"[Benchmark eps=0] no-trade interval: [{bench0_lo:.6f}, {bench0_hi:.6f}], width={bench0_width:.6f}")

# -----------------------------
# Evaluate each eps policy / PMP against eps=0 benchmark
# -----------------------------
rows = []
curve_data = {}

for eps in EPS_LIST:
    key_candidates = [
        k for k in available_keys
        if np.isclose(k[0], FIX_ALPHA) and np.isclose(k[1], FIX_T) and np.isclose(k[2], eps)
    ]
    if len(key_candidates) == 0:
        print(f"[skip] eps={eps} not found.")
        continue

    key = key_candidates[0]
    rr = run_results[key]

    cfg_eps = rr["cfg"]
    policy_eps = rr["policy"]

    device = choose_device(cfg_eps.device)

    stage1 = stage1_action_on_grid(
        policy=policy_eps,
        p_grid=p_grid,
        t_value=t_value,
        cfg=cfg_eps,
        device=device,
    )

    pmp = pmp_project_on_grid(
        policy=policy_eps,
        p_grid=p_grid,
        t_value=t_value,
        cfg=cfg_eps,
        device=device,
    )

    stage1_region = stage1["stage1_region"]
    pmp_region = pmp["pmp_region"]

    valid_stage1 = np.isfinite(stage1_region) & np.isfinite(bench0_region)
    valid_pmp = np.isfinite(pmp_region) & np.isfinite(bench0_region)

    stage1_violation_rate = float(
        np.mean(stage1_region[valid_stage1] != bench0_region[valid_stage1])
    )
    pmp_violation_rate = float(
        np.mean(pmp_region[valid_pmp] != bench0_region[valid_pmp])
    )

    s_lo, s_hi, s_w = _hold_interval(p_grid, stage1_region)
    p_lo, p_hi, p_w = _hold_interval(p_grid, pmp_region)

    rows.append({
        "alpha": cfg_eps.alpha,
        "T": cfg_eps.T,
        "t_frac": FIX_T_FRAC,
        "t": t_value,
        "eps": cfg_eps.eps,

        "stage1_violation_rate_vs_eps0_benchmark": stage1_violation_rate,
        "pmp_violation_rate_vs_eps0_benchmark": pmp_violation_rate,

        "benchmark_eps0_hold_lower": bench0_lo,
        "benchmark_eps0_hold_upper": bench0_hi,
        "benchmark_eps0_hold_width": bench0_width,

        "stage1_hold_lower": s_lo,
        "stage1_hold_upper": s_hi,
        "stage1_hold_width": s_w,

        "pmp_hold_lower": p_lo,
        "pmp_hold_upper": p_hi,
        "pmp_hold_width": p_w,

        "stage1_boundary_mae_vs_eps0_benchmark": _boundary_mae(s_lo, s_hi, bench0_lo, bench0_hi),
        "pmp_boundary_mae_vs_eps0_benchmark": _boundary_mae(p_lo, p_hi, bench0_lo, bench0_hi),
    })

    curve_data[eps] = {
        "p": pmp["p"],
        "R": pmp["R"],
        "u_pmp": pmp["u_pmp"],
        "pmp_region": pmp_region,
        "stage1_region": stage1_region,
        "bench0_region": bench0_region,
    }

summary_df = pd.DataFrame(rows).sort_values("eps").reset_index(drop=True)

