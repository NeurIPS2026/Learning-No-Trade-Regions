    lam_y1 = pmp_plane["lam_y1"]
    lam_y2 = pmp_plane["lam_y2"]
    t_val = float(pmp_plane["time"][0])
    mp = merton_point_wealth_fraction(cfg)

    region1, valid1_ratio, ratio1 = classify_u_star_region_ratio(lam_x, lam_y1, cfg.alpha)
    region2, valid2_ratio, ratio2 = classify_u_star_region_ratio(lam_x, lam_y2, cfg.alpha)

    panels = [
        (region1, valid1_ratio, ratio1, r"Asset 1: region of $u_1^*$"),
        (region2, valid2_ratio, ratio2, r"Asset 2: region of $u_2^*$"),
    ]

    for ax, (region, valid_ratio, ratio, title) in zip(axes, panels):
        valid = valid_plane & valid_ratio
        arr = np.where(valid, region.astype(float), np.nan)

        im = ax.pcolormesh(
