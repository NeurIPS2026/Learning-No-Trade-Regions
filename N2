    txt.append("[F] PMP-u pseudo-flow")
    txt.append("- Flow is a diagnostic relaxation in (y1,y2) coords.")
    txt.append("- Trajectories converging to NTR interior confirm PMP projector correctness.")
    txt.append("")
    txt.append("[G] Comparison interpretation")
    txt.append("- DP/QVI NTR (black dashed) = exact 2D PDE benchmark.")
    txt.append("- PMP 9-region overlay = learned policy trading structure.")
    txt.append("- Agreement in NT zone validates PG-DPO + PMP approach.")
    txt.append("- For rho!=0: NTR tilts along (1,-1) for positive, (1,1) for negative correlation.")
    return "\n".join(txt)


# ============================================================
# Main pipeline
# ============================================================

def run_full_pipeline_2d(cfg: Config2D) -> Dict:
    t0 = time.time()
    set_seed(cfg.seed)
    device = choose_device(cfg.device)
    outdirs = make_output_dirs(cfg.outdir)

    save_json(asdict(cfg), os.path.join(outdirs["base"], "config.json"))
    analysis_times = unique_sorted_step_times(cfg.plane_time, cfg.teacher_times, cfg)

    print("=" * 90)
    print("FULL PIPELINE START (2-ASSET, FINITE-HORIZON DP/QVI BENCHMARK, WEALTH-FRACTION COORDS)")
    print(f"device = {device}")
    print(f"outdir = {cfg.outdir}")
    print(f"Coordinate system: (y1, y2) = (X1/W, X2/W) wealth fractions [논문 기준]")
    print(f"Benchmark: finite-horizon DP/QVI with exact self-financing trade multiplier")
    print("=" * 90)

    # 1) Warm-up training
    print("\n[1/7] Train warm-up policy (PG-DPO)...")
    policy = PolicyNet2D(hidden=cfg.hidden, depth=cfg.depth).to(device)
    train_hist = train_baseline_pg_dpo_2d(policy, cfg, device)

    # 2) Evaluate baseline & PMP
    print("\n[2/7] Evaluate baseline / PMP...")
    baseline_metrics = evaluate_baseline_vectorized_2d(policy, cfg, device)
    pmp_metrics = evaluate_pmp_vectorized_2d(policy, cfg, device)
    print(f"  Baseline EU = {baseline_metrics['EU']:.6f}")
    print(f"  PMP      EU = {pmp_metrics['EU']:.6f}")

    # 3) Finite-horizon DP/QVI benchmark (2D NTR)
    print("\n[3/7] Solve finite-horizon DP/QVI benchmark for 2D NTR...")
    dp_raw_result = solve_dp_qvi_benchmark_2d(cfg)
    dz_results = dp_result_to_rectangular_snapshot(dp_raw_result, cfg)  # legacy name for existing plotting functions

    # 4) PMP planes in (y1, y2) = wealth-fraction coordinates
    print("\n[4/7] Compute PMP planes in (y1, y2) wealth-fraction coordinates...")
    pmp_planes = []
    pmp_by_time = {}
    for tval in analysis_times:
        print(f"  Computing PMP plane at t={tval:.3f}...")
        plane = compute_pmp_plane_pi_at_time(policy, cfg, device, tval)
        pmp_planes.append(plane)
        pmp_by_time[tval] = plane

    # 5) PMP-u pseudo-flow
    print("\n[5/7] Compute PMP-u pseudo-flow...")
    flow_by_time = {}
    for tval in analysis_times:
        flow_by_time[tval] = run_pmp_u_flow_on_plane_pi(pmp_by_time[tval], cfg)

    # 6) Classifier
    print("\n[6/7] Train classifier + predict planes...")
    classifier = train_region_classifier_multitime_pi(pmp_planes, cfg, device)
    pred_planes = {}
    if classifier is not None:
        for tval in analysis_times:
            pred_planes[tval] = predict_classifier_plane_pi_at_time(classifier, cfg, device, tval)

    # 7) Save figures and data
    print("\n[7/7] Save figures / data / analysis...")

    # Training curve
    plot_training_curve(
        os.path.join(outdirs["figures_debug"], "training_curve.png"),
        train_hist
    )

    # DP/QVI NTR snapshots (main benchmark figure)
    plot_dz_ntr_snapshots(
        os.path.join(outdirs["figures_main"], "dz_ntr_snapshots.png"),
        dz_results, cfg
    )

    # Per-time figures
    for tval in analysis_times:
        time_dir = os.path.join(outdirs["figures_main"], f"time_{tval:.2f}")
        ensure_dir(time_dir)
        pmp_plane = pmp_by_time[tval]
        flow_data = flow_by_time[tval]

        # PMP 9-region with DZ overlay
        plot_pmp_region_pi(
            os.path.join(time_dir, f"pmp_region_pi_t{tval:.2f}.png"),
            pmp_plane, dz_results, cfg
        )

                # Costate ratio heatmap: R_i = lambda_{y_i} / lambda_x
        plot_costate_ratio_heatmap_pi(
            os.path.join(time_dir, f"costate_ratio_heatmap_pi_t{tval:.2f}.png"),
            pmp_plane,
            cfg
        )
    
        plot_u_star_region_assetwise_pi(
            os.path.join(cfg.outdir, "u_star_region_assetwise_pi.png"),
            pmp_plane,
            cfg
        )

        # DZ vs PMP comparison
        plot_dz_comparison_with_pmp(
            os.path.join(time_dir, f"dz_vs_pmp_comparison_t{tval:.2f}.png"),
            dz_results, pmp_plane, cfg
        )

        # Action panel
        plot_action_panel_pi(
    os.path.join(time_dir, f"action_panel_pi_t{tval:.2f}.png"),
    pmp_plane, cfg, dz_results=dz_results
)

        plot_u_norms_heatmap_pi(
    os.path.join(time_dir, f"u_norms_heatmap_pi_t{tval:.2f}.png"),
    pmp_plane,
    cfg
)
        # Quiver with DZ overlay
        plot_pmp_u_quiver_pi(
            os.path.join(time_dir, f"pmp_u_quiver_pi_t{tval:.2f}.png"),
            pmp_plane, dz_results, cfg
        )

        # Sample trajectories with DZ overlay
        plot_pmp_u_sample_trajectories_pi(
            os.path.join(time_dir, f"pmp_u_trajectories_pi_t{tval:.2f}.png"),
            pmp_plane, flow_data, dz_results, cfg
        )

        # Endpoint density
        plot_pmp_u_endpoint_density_pi(
            os.path.join(time_dir, f"pmp_u_endpoint_density_pi_t{tval:.2f}.png"),
            flow_data, dz_results, cfg
        )

        # Classifier
        if tval in pred_planes:
            pred = pred_planes[tval]
            plot_classifier_region_pi(
                os.path.join(time_dir, f"classifier_region_pi_t{tval:.2f}.png"),
                pred, cfg
            )
        plot_prob_notrade_pi(
    os.path.join(time_dir, f"prob_notrade_pi_t{tval:.2f}.png"),
    pred,
    cfg,
    dz_results=dz_results,
)
    # Save data
    for tval, plane in pmp_by_time.items():
        d = {k: v for k, v in plane.items() if isinstance(v, np.ndarray)}
        save_npz(os.path.join(outdirs["data"], f"pmp_plane_pi_t_{tval:.2f}.npz"), **d)

    for tval, pred in pred_planes.items():
        d = {k: v for k, v in pred.items() if isinstance(v, np.ndarray)}
        save_npz(os.path.join(outdirs["data"], f"classifier_plane_pi_t_{tval:.2f}.npz"), **d)

    for tval, flow_data in flow_by_time.items():
        save_npz(os.path.join(outdirs["data"], f"flow_pi_t_{tval:.2f}.npz"), **flow_data)

    # Save DZ snapshots
    for step, snap in dz_results['snapshots'].items():
        d = {k: v for k, v in snap.items() if isinstance(v, np.ndarray)}
        save_npz(os.path.join(outdirs["data"], f"dz_snap_step_{step}.npz"), **d)
    save_npz(os.path.join(outdirs["data"], "dz_grids.npz"),
             y1g=dz_results['y1g'], y2g=dz_results['y2g'])

    # Summary
    metrics = summarize_results(baseline_metrics, pmp_metrics)
    mp = merton_point_wealth_fraction(cfg)
    metrics["elapsed_sec"] = float(time.time() - t0)
    metrics["merton_y1"] = float(mp[0])
    metrics["merton_y2"] = float(mp[1])
    save_json(metrics, os.path.join(outdirs["base"], "metrics.json"))

    summary_lines = [
        f"elapsed_sec: {metrics['elapsed_sec']:.2f}",
        f"baseline_EU: {baseline_metrics['EU']:.8f}",
        f"pmp_EU:      {pmp_metrics['EU']:.8f}",
        f"EU_gain:     {metrics['EU_gain_pmp_minus_baseline']:.8f}",
        f"merton_y1:   {mp[0]:.6f}",
        f"merton_y2:   {mp[1]:.6f}",
        f"dp_n_grid:   {cfg.dp_n_grid}",
        f"dp_n_steps:  {cfg.dp_n_steps}",
        f"dp_gh_order: {cfg.dp_gh_order}",
        f"coord_system: (y1,y2)=(X1/W, X2/W) wealth fractions [finite-horizon DP/QVI]",
    ]
    with open(os.path.join(outdirs["base"], "summary.txt"), "w", encoding="utf-8") as f:
        f.write("\n".join(summary_lines) + "\n")

    analysis_text = generate_analysis_text(metrics, dz_results, cfg)
    with open(os.path.join(outdirs["base"], "paper_analysis.txt"), "w", encoding="utf-8") as f:
        f.write(analysis_text + "\n")

    print("\n" + "=" * 90)
    print("DONE")
    print(f"Results saved to: {cfg.outdir}")
    print("Main summary:")
    for line in summary_lines:
        print("  " + line)
    print("=" * 90)

    return {
        "cfg": cfg,
        "device": str(device),
        "outdirs": outdirs,
        "policy": policy,
        "classifier": classifier,
        "baseline_metrics": baseline_metrics,
        "pmp_metrics": pmp_metrics,
        "dp_raw_result": dp_raw_result,
        "benchmark_results": dz_results,
        "pmp_by_time": pmp_by_time,
        "pred_planes": pred_planes,
        "flow_by_time": flow_by_time,
        "metrics": metrics,
        "paper_analysis": analysis_text,
    }


