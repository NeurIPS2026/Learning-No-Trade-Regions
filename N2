# PMP projector
# ============================================================

def _expand_shared_noise_2d(noise_bank: torch.Tensor, batch_states: int) -> torch.Tensor:
    return noise_bank.repeat_interleave(batch_states, dim=1)


def pmp_projected_action_batch_2d(
    policy: PolicyNet2D,
    x: torch.Tensor,
    y: torch.Tensor,
    t_value: float,
    cfg: "Config2D",
    device: torch.device,
    noise_bank: Optional[torch.Tensor] = None
) -> Tuple[torch.Tensor, torch.Tensor, torch.Tensor, torch.Tensor, torch.Tensor]:
    start_step = int(round(float(t_value) / cfg.dt))
    start_step = max(0, min(cfg.n_steps - 1, start_step))

    batch_states = x.numel()
    m_eff = int(cfg.inner_mc_paths)

    if cfg.use_antithetic:
        _, total_count = _base_noise_count(m_eff, True)
        m_paths = total_count
    else:
        m_paths = m_eff

    x_rep = x.view(1, batch_states).repeat(m_paths, 1).reshape(-1).clone().detach().requires_grad_(True)
    y_rep = y.view(1, batch_states, 2).repeat(m_paths, 1, 1).reshape(-1, 2).clone().detach().requires_grad_(True)

    if noise_bank is None:
        remaining = cfg.n_steps - start_step
        if remaining > 0:
            base_count, total_count = _base_noise_count(m_eff, cfg.use_antithetic)
            z = torch.randn((remaining, base_count, batch_states, 2), device=device)
            base = make_correlated_dW(z, cfg)
            if cfg.use_antithetic:
                noise = torch.cat([base, -base], dim=1)[:, :total_count, :, :]
            else:
                noise = base
            noise = noise.permute(0, 2, 1, 3).reshape(remaining, batch_states * m_paths, 2)
        else:
            noise = None
    else:
        noise = _expand_shared_noise_2d(noise_bank[:, :m_paths, :], batch_states)

    xT, yT = rollout_policy_2d(policy, x_rep, y_rep, start_step, noise, cfg)
    payoff = utility(liquidation_wealth_2d(xT, yT, cfg.alpha), cfg.gamma)
    grad_x, grad_y = torch.autograd.grad(payoff.sum(), [x_rep, y_rep], create_graph=False)

    lam_x = grad_x.view(m_paths, batch_states).mean(dim=0)
    lam_y = grad_y.view(m_paths, batch_states, 2).mean(dim=0)

    lam_x_safe = torch.clamp(lam_x, min=cfg.lambda_floor).unsqueeze(-1)
    buy_gap = lam_y - lam_x.unsqueeze(-1)
    sell_gap = (1.0 - cfg.alpha) * lam_x.unsqueeze(-1) - lam_y

    denom = torch.clamp(cfg.eps_quad * lam_x_safe, min=cfg.lambda_floor)
    u_buy = torch.relu(buy_gap / denom)
    u_sell = torch.relu(sell_gap / denom)
    u_pmp = u_buy - u_sell
    u_pmp = project_rate_vector(u_pmp, x.detach(), y.detach(), cfg)

    return u_pmp.detach(), lam_x.detach(), lam_y.detach(), buy_gap.detach(), sell_gap.detach()


def evaluate_pmp_vectorized_2d(policy: PolicyNet2D, cfg: "Config2D", device: torch.device) -> Dict:
    reps = int(cfg.outer_eval_paths)
    chunk_size = max(1, int(cfg.eval_chunk_size))
    liq_chunks = []

    for start in range(0, reps, chunk_size):
        bsz = min(chunk_size, reps - start)
        x = torch.full((bsz,), cfg.x0_eval, device=device)
        y = torch.tensor([cfg.y10_eval, cfg.y20_eval], dtype=torch.float32, device=device).view(1, 2).repeat(bsz, 1)
        outer_bank = build_forward_noise_bank(0, cfg, device=device, batch_size=bsz) if cfg.use_common_random_numbers else None

        for step in range(cfg.n_steps):
            t_val = step * cfg.dt
            inner_bank = build_shared_noise_bank(step, cfg, device=device, m=cfg.inner_mc_paths) if cfg.use_common_random_numbers else None
            u, _, _, _, _ = pmp_projected_action_batch_2d(policy, x, y, t_val, cfg, device, noise_bank=inner_bank)

            if outer_bank is None:
                dW = make_correlated_dW(torch.randn(bsz, 2, device=device), cfg)
            else:
                dW = outer_bank[step, :bsz, :]
            x, y = step_dynamics_from_rate_2d(x, y, u, dW, cfg)

        liq_chunks.append(liquidation_wealth_2d(x, y, cfg.alpha).detach().cpu())

    liqT = torch.cat(liq_chunks, dim=0)
    return {
        "EU": float(utility(liqT, cfg.gamma).mean().item()),
        "mean_liq": float(liqT.mean().item()),
        "std_liq": float(liqT.std(unbiased=False).item()),
    }


# ============================================================
# ================================================================
# DAI & ZHONG (2010) PENALTY METHOD - 2D NTR BENCHMARK
# ================================================================
# Implements Section 3-5 of the paper for N=2, kappa=0 (no consumption).
#
# After change-of-variables (Sec 3), the value function W(y,t) satisfies
# variational inequality (3.4) in Omega^2 x [0,T):
#
#   max{ dW/dt + L*W,  max_i L_i*W,  max_i M_i*W } = 0
#
# with terminal condition W(y,T) = log(1 - mu*y1^+ - lambda*y1^- - mu*y2^+ - lambda*y2^-)
# (symmetric costs: lambda=mu=alpha)
#
# Penalty approximation (4.1):
#   -dW/dt - L*W = K * sum_i [(L_i W)^+ + (M_i W)^+]
#
# We solve backward in time with fully implicit FD + non-smooth Newton iteration.
# ================================================================

def _dz_operators_2d(y1g: np.ndarray, y2g: np.ndarray, cfg: "Config2D") -> Dict:
    """
    Precompute coefficients for the PDE operator at all interior grid points.
    Grid: y1g (Ny1 points), y2g (Ny2 points).
    State: y = (y1, y2) = wealth fractions.
    
    PDE operator (eq 3.4, kappa=0):
      LW = sum_{k,l} a_{k,l} (W_{y_k y_l} + gamma * W_{y_k} * W_{y_l})
           + sum_k b_k W_{y_k} - theta
    where (no-consumption, gamma = dz_gamma = 1 - CRRA_gamma):
      a_{k,l} = y_k y_l sum_{i,j} (1/2) rho_ij sigma_i sigma_j (delta_il - y_i)(delta_jk - y_j)
      b_k = y_k sum_i (delta_ik - y_i) [(alpha_i - r) + (gamma-1) sum_j rho_ij sigma_i sigma_j y_j]
      theta = beta/gamma - (r + sum_i y_i (alpha_i - r - (1-gamma)/2 * sum_j rho_ij sigma_i sigma_j y_j))
    For our case: beta=0 (no discounting beyond utility), so theta has no beta term.
    Actually in the investment-only (kappa=0, no consumption, no discount) case:
      theta = -(r + sum_i y_i (alpha_i - r - (1-gamma)/2 * sum_j rho_ij sigma_i sigma_j y_j))
    
    Gradient constraints (buying asset i: L_i W >= 0, selling: M_i W >= 0):
      L_i W = sum_k (delta_ik + lambda_i y_k) W_{y_k} - lambda_i   [buy constraint]
      M_i W = sum_k (-delta_ik + mu_i y_k) W_{y_k} - mu_i          [sell constraint]
    With lambda=mu=alpha (symmetric costs).
    """
    N1 = len(y1g)
    N2 = len(y2g)
    
    gam = cfg.dz_gamma          # paper's gamma (negative for CRRA>1)
    r = cfg.r
    alpha_arr = np.array([cfg.alpha, cfg.alpha])   # lambda=mu=alpha
    mu_arr = alpha_arr
    lam_arr = alpha_arr
    
    sig = np.array(cfg.sigma, dtype=np.float64)
    mu_ret = np.array(cfg.mu, dtype=np.float64)
    rho = float(cfg.rho)
    
    # Covariance matrix entries
    Sig = np.array([[sig[0]**2, rho*sig[0]*sig[1]],
                    [rho*sig[0]*sig[1], sig[1]**2]], dtype=np.float64)
    
    Y1, Y2 = np.meshgrid(y1g, y2g, indexing='ij')  # shape (N1, N2)
    y = np.stack([Y1, Y2], axis=-1)  # (N1, N2, 2)
    
    # Compute a_{k,l} for k,l in {0,1}
    # a_{k,l} = y_k y_l * sum_{i,j} 0.5 rho_ij sig_i sig_j (delta_{il}-y_i)(delta_{jk}-y_j)
    def compute_a(k, l, y):
        acc = np.zeros(y.shape[:2])
        for i in range(2):
            for j in range(2):
                dil = (1.0 if i == l else 0.0) - y[..., i]
                djk = (1.0 if j == k else 0.0) - y[..., j]
                acc += 0.5 * Sig[i, j] * dil * djk
        return y[..., k] * y[..., l] * acc
    
    a00 = compute_a(0, 0, y)
    a11 = compute_a(1, 1, y)
    a01 = compute_a(0, 1, y)  # symmetric: a01 = a10
    
    # Compute b_k
    def compute_b(k, y):
        acc = np.zeros(y.shape[:2])
        for i in range(2):
            dik = 1.0 if i == k else 0.0
            inner = (mu_ret[i] - r)
            for j in range(2):
                inner += (gam - 1.0) * Sig[i, j] * y[..., j]
            acc += (dik - y[..., i]) * inner
        return y[..., k] * acc
    
    b0 = compute_b(0, y)
    b1 = compute_b(1, y)
    
    # Compute theta (no discount beta=0)
    theta = np.zeros_like(Y1)
    for i in range(2):
        inner = mu_ret[i] - r
        for j in range(2):
            inner -= (1.0 - gam) / 2.0 * Sig[i, j] * y[..., j]
        theta += y[..., i] * inner
    theta = -(r + theta)
    
    return {
        'a00': a00, 'a11': a11, 'a01': a01,
        'b0': b0, 'b1': b1,
        'theta': theta,
        'Y1': Y1, 'Y2': Y2,
        'N1': N1, 'N2': N2,
        'lam': lam_arr, 'mu_c': mu_arr,
        'gam': gam,
    }


def _dz_build_A_matrix(coefs: Dict, y1g: np.ndarray, y2g: np.ndarray, dt: float) -> sp.csr_matrix:
    """
    Build the linear operator A for the fully-implicit FD scheme (without penalty terms).
    A is a sparse (N1*N2) x (N1*N2) matrix such that the scheme at step n is:
       (I + dt*A) W^{n} = W^{n+1} + dt*theta  (plus penalty corrections)
    
    We use upwind for first-order terms and standard 2nd-order for pure second-order.
    Cross derivative: standard mixed discretization (sign-dependent).
    """
    N1, N2 = len(y1g), len(y2g)
    N = N1 * N2
    h1 = y1g[1] - y1g[0]
    h2 = y2g[1] - y2g[0]
    
    a00 = coefs['a00']
    a11 = coefs['a11']
    a01 = coefs['a01']
    b0 = coefs['b0']
    b1 = coefs['b1']
    
    def idx(i, j):
        return i * N2 + j
    
    rows, cols, vals = [], [], []
    
    def add(r_, c_, v):
        rows.append(r_)
        cols.append(c_)
        vals.append(v)
    
    for i in range(N1):
        for j in range(N2):
            p = idx(i, j)
            
            # ---- second order d2W/dy1^2 ----
            c00 = a00[i, j] / (h1 * h1)
            if 0 < i < N1 - 1:
                add(p, idx(i+1, j),  c00)
                add(p, p,           -2*c00)
                add(p, idx(i-1, j),  c00)
            else:
                # boundary: zero second derivative (Neumann-like)
                pass
            
            # ---- second order d2W/dy2^2 ----
            c11 = a11[i, j] / (h2 * h2)
            if 0 < j < N2 - 1:
                add(p, idx(i, j+1),  c11)
                add(p, p,           -2*c11)
                add(p, idx(i, j-1),  c11)
            
            # ---- cross derivative d2W/(dy1 dy2) ----
            c_cross = a01[i, j]
            if 0 < i < N1-1 and 0 < j < N2-1:
                if c_cross > 0:
                    coef = c_cross / (2 * h1 * h2)
                    add(p, idx(i+1, j+1),  coef)
                    add(p, idx(i-1, j-1),  coef)
                    add(p, idx(i+1, j),   -coef)
                    add(p, idx(i-1, j),   -coef)
                    add(p, idx(i, j+1),   -coef)
                    add(p, idx(i, j-1),   -coef)
                elif c_cross < 0:
                    coef = -c_cross / (2 * h1 * h2)
                    add(p, idx(i+1, j-1),  coef)
                    add(p, idx(i-1, j+1),  coef)
                    add(p, idx(i+1, j),   -coef)
                    add(p, idx(i-1, j),   -coef)
                    add(p, idx(i, j+1),   -coef)
                    add(p, idx(i, j-1),   -coef)
            
            # ---- first order upwind dW/dy1 ----
            b0v = b0[i, j]
            if b0v > 0:
                if i < N1 - 1:
                    coef = b0v / h1
                    add(p, idx(i+1, j),  coef)
                    add(p, p,           -coef)
            else:
                if i > 0:
                    coef = -b0v / h1
                    add(p, idx(i-1, j), -coef)
                    add(p, p,            coef)
            
            # ---- first order upwind dW/dy2 ----
            b1v = b1[i, j]
            if b1v > 0:
                if j < N2 - 1:
                    coef = b1v / h2
                    add(p, idx(i, j+1),  coef)
                    add(p, p,           -coef)
            else:
                if j > 0:
                    coef = -b1v / h2
                    add(p, idx(i, j-1), -coef)
                    add(p, p,            coef)
    
    A = sp.csr_matrix((vals, (rows, cols)), shape=(N, N))
    return A


def _dz_penalty_residual(W: np.ndarray, W_next: np.ndarray, A: sp.csr_matrix,
                          coefs: Dict, y1g: np.ndarray, y2g: np.ndarray,
                          dt: float, K: float) -> Tuple[np.ndarray, np.ndarray]:
    """
    Compute penalty residual F(W) = 0:
       F = -(W - W_next)/dt - (L_op W) - theta - K*sum[(L_i W)^+ + (M_i W)^+] = 0
    i.e. (I + dt*A) W - W_next - dt*theta = dt*K*sum[penalty]
    
    Returns (F, penalty_flags) where penalty_flags indicates active constraints.
    """
    N1, N2 = coefs['N1'], coefs['N2']
    N = N1 * N2
    h1 = y1g[1] - y1g[0]
    h2 = y2g[1] - y2g[0]
    lam = coefs['lam']
    mu_c = coefs['mu_c']
    Y1 = coefs['Y1'].ravel()
    Y2 = coefs['Y2'].ravel()
    Wf = W.ravel()
    
    def idx(i, j):
        return i * N2 + j
    
    # L_1 W = (1 + lambda_1*y_1) dW/dy1 + lambda_1*y_2 * dW/dy2 - lambda_1
    # M_1 W = (-1 + mu_1*y_1) dW/dy1 + mu_1*y_2 * dW/dy2 - mu_1
    # Similarly for asset 2.
    
    # Compute forward/backward differences for penalty gradient terms (upwind)
    # For L_i W = sum_k (delta_ik + lam_i y_k) dW/dy_k - lam_i
    # We use upwind: if coefficient > 0 use forward diff, else backward diff
    
    dWdy1_fwd = np.zeros(N)
    dWdy1_bwd = np.zeros(N)
    dWdy2_fwd = np.zeros(N)
    dWdy2_bwd = np.zeros(N)
    
    for i in range(N1):
        for j in range(N2):
            p = idx(i, j)
            if i < N1 - 1:
                dWdy1_fwd[p] = (Wf[idx(i+1, j)] - Wf[p]) / h1
            else:
                dWdy1_fwd[p] = 0.0
            if i > 0:
                dWdy1_bwd[p] = (Wf[p] - Wf[idx(i-1, j)]) / h1
            else:
                dWdy1_bwd[p] = 0.0
            if j < N2 - 1:
                dWdy2_fwd[p] = (Wf[idx(i, j+1)] - Wf[p]) / h2
            else:
                dWdy2_fwd[p] = 0.0
            if j > 0:
                dWdy2_bwd[p] = (Wf[p] - Wf[idx(i, j-1)]) / h2
            else:
                dWdy2_bwd[p] = 0.0
    
    def compute_LiW(asset_idx):
        # L_i W = (delta_{i1}+lam_i*y1) dW/dy1 + (delta_{i2}+lam_i*y2) dW/dy2 - lam_i
        # coefficient for dW/dy1: c1 = (1 if asset_idx==0 else 0) + lam_i * y1
        # Use upwind: if c1>0 forward, else backward
        lam_i = lam[asset_idx]
        c1 = (1.0 if asset_idx == 0 else 0.0) + lam_i * Y1
        c2 = (1.0 if asset_idx == 1 else 0.0) + lam_i * Y2
        dW1 = np.where(c1 >= 0, dWdy1_fwd, dWdy1_bwd)
        dW2 = np.where(c2 >= 0, dWdy2_fwd, dWdy2_bwd)
        return c1 * dW1 + c2 * dW2 - lam_i
    
    def compute_MiW(asset_idx):
        # M_i W = (-delta_{i1}+mu_i*y1) dW/dy1 + (-delta_{i2}+mu_i*y2) dW/dy2 - mu_i
        mu_i = mu_c[asset_idx]
        c1 = (-1.0 if asset_idx == 0 else 0.0) + mu_i * Y1
        c2 = (-1.0 if asset_idx == 1 else 0.0) + mu_i * Y2
        dW1 = np.where(c1 >= 0, dWdy1_fwd, dWdy1_bwd)
        dW2 = np.where(c2 >= 0, dWdy2_fwd, dWdy2_bwd)
        return c1 * dW1 + c2 * dW2 - mu_i
    
    L1W = compute_LiW(0)
    L2W = compute_LiW(1)
    M1W = compute_MiW(0)
    M2W = compute_MiW(1)
    
    penalty = K * (np.maximum(L1W, 0) + np.maximum(L2W, 0)
                   + np.maximum(M1W, 0) + np.maximum(M2W, 0))
    
    theta_f = coefs['theta'].ravel()
    # Residual of the implicit scheme:
    # (W - W_next)/dt + (L_op W) + theta = -penalty  [penalty on RHS]
    # F = (W - W_next)/dt + (L_op W) + theta + penalty = 0
    AW = A.dot(Wf)
    F = (Wf - W_next.ravel()) / dt - AW - theta_f + penalty
    
    penalty_flags = {
        'L1': L1W, 'L2': L2W, 'M1': M1W, 'M2': M2W,
        'dWdy1_fwd': dWdy1_fwd, 'dWdy1_bwd': dWdy1_bwd,
        'dWdy2_fwd': dWdy2_fwd, 'dWdy2_bwd': dWdy2_bwd,
    }
    return F, penalty_flags


def _dz_build_Jacobian(W: np.ndarray, coefs: Dict, y1g: np.ndarray, y2g: np.ndarray,
                        A: sp.csr_matrix, dt: float, K: float,
                        penalty_flags: Dict) -> sp.csr_matrix:
    """
    Build Jacobian of the penalty residual via non-smooth Newton.
    Linearize (L_i W)^+ as K*L_i W if L_i W >= 0, else 0.
    """
    N1, N2 = coefs['N1'], coefs['N2']
    N = N1 * N2
    h1 = y1g[1] - y1g[0]
    h2 = y2g[1] - y2g[0]
    lam = coefs['lam']
    mu_c = coefs['mu_c']
    Y1 = coefs['Y1'].ravel()
    Y2 = coefs['Y2'].ravel()
    
    def idx(i, j):
        return i * N2 + j
    
    # Base: (1/dt)*I - A
    J_base = sp.eye(N, format='csr') / dt - A
    
    # Add penalty Jacobians (non-smooth Newton: linearize at current iterate)
    rows, cols, vals = [], [], []
    
    def add(r_, c_, v):
        if v != 0.0:
            rows.append(r_)
            cols.append(c_)
            vals.append(v)
    
    L1 = penalty_flags['L1']
    L2 = penalty_flags['L2']
    M1 = penalty_flags['M1']
    M2 = penalty_flags['M2']
    
    dWdy1_fwd = penalty_flags['dWdy1_fwd']
    dWdy1_bwd = penalty_flags['dWdy1_bwd']
    dWdy2_fwd = penalty_flags['dWdy2_fwd']
    dWdy2_bwd = penalty_flags['dWdy2_bwd']
    
    for i in range(N1):
        for j in range(N2):
            p = idx(i, j)
            
            # L_1 W >= 0 ? add K * d(L_1 W)/dW
            for (LiW_arr, asset_idx, sign) in [(L1, 0, 1), (L2, 1, 1),
                                                (M1, 0, -1), (M2, 1, -1)]:
                if LiW_arr[p] >= 0:
                    lam_i = lam[asset_idx] if sign == 1 else mu_c[asset_idx]
                    # coefficient for dW/dy1
                    if sign == 1:  # L_i W
                        c1 = (1.0 if asset_idx == 0 else 0.0) + lam_i * Y1[p]
                        c2 = (1.0 if asset_idx == 1 else 0.0) + lam_i * Y2[p]
                    else:  # M_i W
                        c1 = (-1.0 if asset_idx == 0 else 0.0) + lam_i * Y1[p]
                        c2 = (-1.0 if asset_idx == 1 else 0.0) + lam_i * Y2[p]
                    
                    # d(c1 * dW/dy1)/dW_p: upwind
                    if c1 >= 0:  # forward diff
                        if i < N1 - 1:
                            add(p, idx(i+1, j), K * c1 / h1)
                            add(p, p, -K * c1 / h1)
                    else:  # backward diff
                        if i > 0:
                            add(p, idx(i-1, j), -K * c1 / h1)
                            add(p, p, K * c1 / h1)
                    
                    if c2 >= 0:  # forward diff
                        if j < N2 - 1:
                            add(p, idx(i, j+1), K * c2 / h2)
                            add(p, p, -K * c2 / h2)
                    else:
                        if j > 0:
                            add(p, idx(i, j-1), -K * c2 / h2)
                            add(p, p, K * c2 / h2)
    
    J_pen = sp.csr_matrix((vals, (rows, cols)), shape=(N, N))
    return J_base + J_pen

