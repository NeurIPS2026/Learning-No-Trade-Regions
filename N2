class PolicyNet2D(nn.Module):
    def __init__(self, hidden: int = 96, depth: int = 2):
        super().__init__()
        layers: List[nn.Module] = []
        in_dim = 4  # t/T, logW, y1, y2  (wealth-fraction coords)
        for _ in range(depth):
            layers.append(nn.Linear(in_dim, hidden))
            layers.append(nn.Tanh())
            in_dim = hidden
        layers.append(nn.Linear(in_dim, 2))
        self.net = nn.Sequential(*layers)

    def forward(self, x: torch.Tensor) -> torch.Tensor:
        return self.net(x)


class RegionClassifier2D(nn.Module):
    def __init__(self, in_dim: int = 3, hidden: int = 96, depth: int = 2):
        super().__init__()
        layers: List[nn.Module] = []
        d = in_dim
        for _ in range(depth):
            layers.append(nn.Linear(d, hidden))
            layers.append(nn.Tanh())
            d = hidden
        layers.append(nn.Linear(d, 1))
        self.net = nn.Sequential(*layers)

    def forward(self, x: torch.Tensor) -> torch.Tensor:
        return self.net(x)


