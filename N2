def summarize_results(baseline_metrics: Dict, pmp_metrics: Dict) -> Dict:
    out = {}
    for k, v in baseline_metrics.items():
        out[f"baseline_{k}"] = float(v)
    for k, v in pmp_metrics.items():
        out[f"pmp_{k}"] = float(v)
    out["EU_gain_pmp_minus_baseline"] = float(pmp_metrics["EU"] - baseline_metrics["EU"])
    return out


