            t_arr,
            np.clip(1.0 - t_arr, cfg.pi2_min, cfg.pi2_max),
            "k-", linewidth=0.9, alpha=0.35
        )

        ax.set_xlim(cfg.pi1_min, cfg.pi1_max)
