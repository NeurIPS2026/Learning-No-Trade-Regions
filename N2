def _compute_pde_coefficients(y1g: np.ndarray, y2g: np.ndarray, cfg) -> Dict:
    N1, N2 = len(y1g), len(y2g)
    gam = float(cfg.dz_gamma)   # paper gamma = 1 - CRRA_gamma
    r = float(cfg.r)

    sig = np.array(cfg.sigma, dtype=np.float64)
    mu_ret = np.array(cfg.mu, dtype=np.float64)
    rho = float(cfg.rho)

    Sig = np.array([
        [sig[0] ** 2,         rho * sig[0] * sig[1]],
        [rho * sig[0] * sig[1], sig[1] ** 2]
    ], dtype=np.float64)

    Y1, Y2 = np.meshgrid(y1g, y2g, indexing="ij")
    y = np.stack([Y1, Y2], axis=-1)

    def a_kl(k, l):
        acc = np.zeros((N1, N2), dtype=np.float64)
        for i in range(2):
            for j in range(2):
                acc += 0.5 * Sig[i, j] * ((1.0 if i == l else 0.0) - y[..., i]) * ((1.0 if j == k else 0.0) - y[..., j])
        return y[..., k] * y[..., l] * acc

    a00 = a_kl(0, 0)
    a11 = a_kl(1, 1)
    a01 = a_kl(0, 1)

    def b_k(k):
        acc = np.zeros((N1, N2), dtype=np.float64)
        for i in range(2):
            inner = (mu_ret[i] - r) + (gam - 1.0) * (
                Sig[i, 0] * y[..., 0] + Sig[i, 1] * y[..., 1]
            )
            acc += ((1.0 if i == k else 0.0) - y[..., i]) * inner
        return y[..., k] * acc

    b0 = b_k(0)
    b1 = b_k(1)

    theta = np.zeros((N1, N2), dtype=np.float64)
    for i in range(2):
        inner = (mu_ret[i] - r) - (1.0 - gam) / 2.0 * (
            Sig[i, 0] * y[..., 0] + Sig[i, 1] * y[..., 1]
        )
        theta += y[..., i] * inner
    theta = -(r + theta)

    return dict(
        a00=a00, a11=a11, a01=a01,
        b0=b0, b1=b1,
        theta=theta,
        Y1=Y1, Y2=Y2,
        N1=N1, N2=N2,
        gam=gam
    )


def _build_A_matrix(coefs: Dict, y1g: np.ndarray, y2g: np.ndarray) -> sp.csr_matrix:
    """
    A approximates the LINEAR part:
        A W ≈ a00 W_y1y1 + 2 a01 W_y1y2 + a11 W_y2y2 + b0 W_y1 + b1 W_y2
    so the residual is:
        (W - W_next)/dt + A W + NL(W) - theta + penalty = 0
    """
    N1, N2 = coefs["N1"], coefs["N2"]
    N = N1 * N2
    h1 = y1g[1] - y1g[0]
    h2 = y2g[1] - y2g[0]

    a00, a11, a01 = coefs["a00"], coefs["a11"], coefs["a01"]
    b0, b1 = coefs["b0"], coefs["b1"]

    def idx(i, j):
        return i * N2 + j

    rows, cols, vals = [], [], []

    def add(r_, c_, v_):
        if abs(v_) > 0:
            rows.append(int(r_))
            cols.append(int(c_))
            vals.append(float(v_))

    for i in range(N1):
        for j in range(N2):
            p = idx(i, j)

            # d2/dy1^2
            c = a00[i, j] / (h1 * h1)
            if 0 < i < N1 - 1:
                add(p, idx(i + 1, j), c)
                add(p, p, -2.0 * c)
                add(p, idx(i - 1, j), c)

            # d2/dy2^2
            c = a11[i, j] / (h2 * h2)
            if 0 < j < N2 - 1:
                add(p, idx(i, j + 1), c)
                add(p, p, -2.0 * c)
                add(p, idx(i, j - 1), c)

            # mixed derivative: use the same paper-style stencil as your second implementation
            ac = a01[i, j]
            if abs(ac) > 1e-15 and 0 < i < N1 - 1 and 0 < j < N2 - 1:
                coef = abs(ac) / (2.0 * h1 * h2)
                if ac > 0:
                    add(p, idx(i + 1, j + 1),  coef)
                    add(p, idx(i - 1, j - 1),  coef)
                    add(p, p,                  2.0 * coef)
                    add(p, idx(i + 1, j),     -coef)
                    add(p, idx(i - 1, j),     -coef)
                    add(p, idx(i, j + 1),     -coef)
                    add(p, idx(i, j - 1),     -coef)
                else:
                    add(p, idx(i + 1, j - 1),  coef)
                    add(p, idx(i - 1, j + 1),  coef)
                    add(p, p,                  2.0 * coef)
                    add(p, idx(i + 1, j),     -coef)
                    add(p, idx(i - 1, j),     -coef)
                    add(p, idx(i, j + 1),     -coef)
                    add(p, idx(i, j - 1),     -coef)

            # upwind first derivative y1
            bv = b0[i, j]
            if bv >= 0:
                if i < N1 - 1:
                    c = bv / h1
                    add(p, idx(i + 1, j), c)
                    add(p, p, -c)
            else:
                if i > 0:
                    c = -bv / h1
                    add(p, idx(i - 1, j), -c)
                    add(p, p, c)

            # upwind first derivative y2
            bv = b1[i, j]
            if bv >= 0:
                if j < N2 - 1:
                    c = bv / h2
                    add(p, idx(i, j + 1), c)
                    add(p, p, -c)
            else:
                if j > 0:
                    c = -bv / h2
                    add(p, idx(i, j - 1), -c)
                    add(p, p, c)

    return sp.csr_matrix((vals, (rows, cols)), shape=(N, N))


def _nonlinear_LW(W2d: np.ndarray, coefs: Dict, h1: float, h2: float) -> np.ndarray:
    gam = coefs["gam"]
    if abs(gam) < 1e-14:
        return np.zeros_like(W2d)

    Wy1 = np.zeros_like(W2d)
    Wy2 = np.zeros_like(W2d)

    Wy1[1:-1, :] = (W2d[2:, :] - W2d[:-2, :]) / (2.0 * h1)
    Wy1[0, :]    = (W2d[1, :] - W2d[0, :]) / h1
    Wy1[-1, :]   = (W2d[-1, :] - W2d[-2, :]) / h1

    Wy2[:, 1:-1] = (W2d[:, 2:] - W2d[:, :-2]) / (2.0 * h2)
    Wy2[:, 0]    = (W2d[:, 1] - W2d[:, 0]) / h2
    Wy2[:, -1]   = (W2d[:, -1] - W2d[:, -2]) / h2

    return gam * (
        coefs["a00"] * Wy1**2
        + 2.0 * coefs["a01"] * Wy1 * Wy2
        + coefs["a11"] * Wy2**2
    )


def _gradient_constraints(W2d: np.ndarray, coefs: Dict, h1: float, h2: float, alpha: float) -> Dict:
    N1, N2 = W2d.shape
    Y1, Y2 = coefs["Y1"], coefs["Y2"]

    dW1f = np.zeros((N1, N2))
    dW1b = np.zeros((N1, N2))
    dW2f = np.zeros((N1, N2))
    dW2b = np.zeros((N1, N2))

    dW1f[:-1, :] = (W2d[1:, :] - W2d[:-1, :]) / h1
    dW1b[1:,  :] = (W2d[1:, :] - W2d[:-1, :]) / h1
    dW2f[:, :-1] = (W2d[:, 1:] - W2d[:, :-1]) / h2
    dW2b[:, 1: ] = (W2d[:, 1:] - W2d[:, :-1]) / h2

    def cons(asset, sign):
        c1 = sign * (1.0 if asset == 0 else 0.0) + alpha * Y1
        c2 = sign * (1.0 if asset == 1 else 0.0) + alpha * Y2
        g1 = np.where(c1 >= 0, dW1f, dW1b)
        g2 = np.where(c2 >= 0, dW2f, dW2b)
        return c1 * g1 + c2 * g2 - alpha

    return dict(
        L1W=cons(0,  1), L2W=cons(1,  1),
        M1W=cons(0, -1), M2W=cons(1, -1),
    )


def _penalty_residual(W2d, W2d_next, A, coefs, y1g, y2g, dt, K, alpha):
    h1 = y1g[1] - y1g[0]
    h2 = y2g[1] - y2g[0]

    Wf = W2d.ravel()
    Wf_next = W2d_next.ravel()

    AW = A.dot(Wf)
    NL = _nonlinear_LW(W2d, coefs, h1, h2).ravel()
    theta = coefs["theta"].ravel()

    gc = _gradient_constraints(W2d, coefs, h1, h2, alpha)
    pen = K * (
        np.maximum(gc["L1W"].ravel(), 0.0)
        + np.maximum(gc["L2W"].ravel(), 0.0)
        + np.maximum(gc["M1W"].ravel(), 0.0)
        + np.maximum(gc["M2W"].ravel(), 0.0)
    )

    # CONSISTENT SIGN CONVENTION
    F = (Wf - Wf_next) / dt + AW + NL - theta + pen
    return F, gc


def _build_jacobian(W2d, gc, A, coefs, y1g, y2g, dt, K, alpha):
    """
    Frozen-NL Newton: Jacobian ignores d(NL)/dW, but remains consistent with residual.
    """
    N1, N2 = coefs["N1"], coefs["N2"]
    N = N1 * N2
    h1 = y1g[1] - y1g[0]
    h2 = y2g[1] - y2g[0]
    Y1 = coefs["Y1"].ravel()
    Y2 = coefs["Y2"].ravel()

    def idx(i, j):
        return i * N2 + j

    rows, cols, vals = [], [], []

    def add(r_, c_, v_):
        if v_ != 0.0:
            rows.append(int(r_))
            cols.append(int(c_))
            vals.append(float(v_))

    specs = [
        (gc["L1W"].ravel(), 0,  1),
        (gc["L2W"].ravel(), 1,  1),
        (gc["M1W"].ravel(), 0, -1),
        (gc["M2W"].ravel(), 1, -1),
    ]

    for i in range(N1):
        for j in range(N2):
            p = idx(i, j)
            for arr, asset, sign in specs:
                if arr[p] >= 0.0:
                    c1 = sign * (1.0 if asset == 0 else 0.0) + alpha * Y1[p]
                    c2 = sign * (1.0 if asset == 1 else 0.0) + alpha * Y2[p]

                    if c1 >= 0:
                        if i < N1 - 1:
                            add(p, idx(i + 1, j),  K * c1 / h1)
                            add(p, p,             -K * c1 / h1)
                    else:
                        if i > 0:
                            add(p, idx(i - 1, j), -K * c1 / h1)
                            add(p, p,              K * c1 / h1)

                    if c2 >= 0:
                        if j < N2 - 1:
                            add(p, idx(i, j + 1),  K * c2 / h2)
                            add(p, p,             -K * c2 / h2)
                    else:
                        if j > 0:
                            add(p, idx(i, j - 1), -K * c2 / h2)
                            add(p, p,              K * c2 / h2)

    J_pen = sp.csr_matrix((vals, (rows, cols)), shape=(N, N))
    J_base = sp.eye(N, format="csr") / dt + A
    return J_base + J_pen


def solve_dai_zhong_2d(cfg) -> Dict:
    print("  [DZ] clean DP/QVI solver start...")

    alpha = float(cfg.alpha)
    Ny = int(cfg.dz_Ny)
    dt = float(cfg.dt)
    K = float(cfg.dz_K_factor) / dt

    # center domain near Merton point
    sig_arr = np.array(cfg.sigma, dtype=np.float64)
    mu_arr = np.array(cfg.mu, dtype=np.float64)
    rho = float(cfg.rho)
    Sig_full = np.array([
        [sig_arr[0]**2, rho * sig_arr[0] * sig_arr[1]],
        [rho * sig_arr[0] * sig_arr[1], sig_arr[1]**2]
    ], dtype=np.float64)
    excess = mu_arr - float(cfg.r)
    try:
        mp = np.linalg.solve(float(cfg.gamma) * Sig_full, excess)
    except Exception:
        mp = np.linalg.pinv(float(cfg.gamma) * Sig_full) @ excess
    mp_c = np.clip(mp, 0.05, 0.75)

    margin = 0.20
    max_y = 0.90 / (1.0 + alpha)
    y1_lo = max(0.005, mp_c[0] - margin)
    y1_hi = min(max_y, mp_c[0] + margin)
    y2_lo = max(0.005, mp_c[1] - margin)
    y2_hi = min(max_y, mp_c[1] + margin)
    if y1_hi <= y1_lo + 0.02:
        y1_lo, y1_hi = 0.02, 0.60
    if y2_hi <= y2_lo + 0.02:
        y2_lo, y2_hi = 0.02, 0.60

    y1g = np.linspace(y1_lo, y1_hi, Ny, dtype=np.float64)
    y2g = np.linspace(y2_lo, y2_hi, Ny, dtype=np.float64)

    coefs = _compute_pde_coefficients(y1g, y2g, cfg)
    A = _build_A_matrix(coefs, y1g, y2g)

    # terminal condition consistent with gamma convention
    Y1 = coefs["Y1"]
    Y2 = coefs["Y2"]
    solv = np.maximum(1.0 - alpha * (Y1 + Y2), 1e-14)
    if abs(cfg.dz_gamma) < 1e-12:
        W_cur = np.log(solv)
    else:
        W_cur = solv ** cfg.dz_gamma / cfg.dz_gamma

    n_snaps = max(2, int(cfg.dz_n_snapshots))
    snap_steps = set(np.linspace(0, cfg.n_steps - 1, n_snaps, dtype=int).tolist())
    snap_steps.add(0)

    results = {
        "y1g": y1g,
        "y2g": y2g,
        "snapshots": {},
        "domain": dict(y1_lo=y1_lo, y1_hi=y1_hi, y2_lo=y2_lo, y2_hi=y2_hi),
    }

    NTR_TOL = 5e-4

    for step in range(cfg.n_steps - 1, -1, -1):
        W_next = W_cur.copy()
        W_iter = W_next.copy()

        for nit in range(int(cfg.dz_newton_maxiter)):
            F, gc = _penalty_residual(W_iter, W_next, A, coefs, y1g, y2g, dt, K, alpha)
            res = float(np.max(np.abs(F)))
            if res < float(cfg.dz_newton_tol):
                break

            J = _build_jacobian(W_iter, gc, A, coefs, y1g, y2g, dt, K, alpha)
            try:
                dW = spla.spsolve(J, -F)
            except Exception:
                dW = spla.lsqr(J, -F)[0]

            if not np.all(np.isfinite(dW)):
                print(f"    [DZ] non-finite Newton step at step={step}, iter={nit}")
                break

            # damping / backtracking
            step_size = 1.0
            base_res = res
            updated = False
            for _ in range(10):
                cand = W_iter + step_size * dW.reshape(W_iter.shape)
                F_cand, _ = _penalty_residual(cand, W_next, A, coefs, y1g, y2g, dt, K, alpha)
                cand_res = float(np.max(np.abs(F_cand)))
                if np.isfinite(cand_res) and cand_res <= base_res:
                    W_iter = cand
                    updated = True
                    break
                step_size *= 0.5

            if not updated:
                W_iter = W_iter + 0.1 * dW.reshape(W_iter.shape)

        W_cur = W_iter

        if step in snap_steps:
            _, gc_s = _penalty_residual(W_cur, W_cur, A, coefs, y1g, y2g, dt, K, alpha)
            L1, L2 = gc_s["L1W"], gc_s["L2W"]
            M1, M2 = gc_s["M1W"], gc_s["M2W"]

            ntr = (L1 < NTR_TOL) & (L2 < NTR_TOL) & (M1 < NTR_TOL) & (M2 < NTR_TOL)

            a1 = np.zeros_like(L1, dtype=np.int32)
            a2 = np.zeros_like(L2, dtype=np.int32)
            a1[L1 >= NTR_TOL] = 1
            a1[M1 >= NTR_TOL] = -1
            a2[L2 >= NTR_TOL] = 1
            a2[M2 >= NTR_TOL] = -1

            r9 = np.zeros_like(a1, dtype=np.int32)
            r9[(a1 == 0)  & (a2 == 0)]  = 0
            r9[(a1 == 1)  & (a2 == 0)]  = 1
            r9[(a1 == -1) & (a2 == 0)]  = 2
            r9[(a1 == 0)  & (a2 == 1)]  = 3
            r9[(a1 == 0)  & (a2 == -1)] = 4
            r9[(a1 == 1)  & (a2 == 1)]  = 5
            r9[(a1 == -1) & (a2 == -1)] = 6
            r9[(a1 == 1)  & (a2 == -1)] = 7
            r9[(a1 == -1) & (a2 == 1)]  = 8

            t_val = float(step * dt)
            results["snapshots"][step] = dict(
                time=t_val,
                W=W_cur.copy(),
                ntr_mask=ntr,
                region9=r9,
                L1W=L1, L2W=L2, M1W=M1, M2W=M2,
            )
            print(f"  [DZ] step={step:4d}  t={t_val:.3f}  NTR={ntr.mean():.3f}  iters={nit+1}  res={res:.2e}")

    print("  [DZ] done.")
    return results

