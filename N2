        ax.set_xlabel(r"$y_1 = X_1/W$")
        ax.set_ylabel(r"$y_2 = X_2/W$")
        ax.set_title(f"{title}, $t={t_val:.2f}$", fontsize=10)
        ax.grid(alpha=0.2)

    cbar = fig.colorbar(im, ax=axes.ravel().tolist(), fraction=0.03, pad=0.03)
    cbar.set_ticks([0, 1, 2])
