USTAR3_CMAP = ListedColormap([
    "#4C78A8",  # 0 = Sell
    "#DDDDDD",  # 1 = No-trade
    "#E45756",  # 2 = Buy
])
USTAR3_NORM = BoundaryNorm([-0.5, 0.5, 1.5, 2.5], USTAR3_CMAP.N)

def classify_u_star_region_ratio(lam_x, lam_y, alpha, tol=1e-10):
    """
    0 = Sell
    1 = No-trade
    2 = Buy

    Uses ratio r = lam_y / lam_x, but only where lam_x is safely positive.
    Else marks invalid.
    """
    out = np.full(lam_x.shape, -1, dtype=np.int64)  # invalid by default

    valid = lam_x > tol
    r = np.full_like(lam_x, np.nan, dtype=np.float64)
    r[valid] = lam_y[valid] / lam_x[valid]

    out[valid & (r > 1.0 + tol)] = 2
    out[valid & (r < 1.0 - alpha - tol)] = 0
    out[valid & (r >= 1.0 - alpha - tol) & (r <= 1.0 + tol)] = 1
    return out, valid, r


