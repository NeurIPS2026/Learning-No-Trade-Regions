def _valid_pi_plane_mask(PI1: np.ndarray, PI2: np.ndarray, cfg: "Config2D") -> np.ndarray:
    """Valid wealth-fraction states: pi1>=0, pi2>=0, pi1+pi2 < 1, cash > 0 after liquidation."""
    x = cfg.plane_ref_W * (1.0 - PI1 - PI2)
    y1 = cfg.plane_ref_W * PI1
    y2 = cfg.plane_ref_W * PI2
    L = liquidation_wealth_2d_np(x, y1, y2, cfg.alpha)
    return (PI1 >= 0.0) & (PI2 >= 0.0) & (L > cfg.plane_min_liquidation)


def pi_plane_to_xy(PI1: np.ndarray, PI2: np.ndarray, cfg: "Config2D") -> Tuple[np.ndarray, np.ndarray, np.ndarray]:
    W = cfg.plane_ref_W
    y1 = W * PI1
    y2 = W * PI2
    x = W * (1.0 - PI1 - PI2)
    return x, y1, y2


def classifier_features_pi(time_value: float, pi1: np.ndarray, pi2: np.ndarray, cfg: "Config2D") -> np.ndarray:
    return np.stack([
        np.full(pi1.shape, float(time_value) / cfg.T, dtype=np.float64),
        pi1,
        pi2,
    ], axis=-1)


def classify_pmp_u_region(u1: np.ndarray, u2: np.ndarray, tol: float) -> np.ndarray:
    a1 = np.zeros_like(u1, dtype=np.int64)
    a2 = np.zeros_like(u2, dtype=np.int64)
    a1[u1 > tol] = 1
    a1[u1 < -tol] = -1
    a2[u2 > tol] = 1
    a2[u2 < -tol] = -1

    out = np.zeros_like(a1, dtype=np.int64)
    out[(a1 == 0) & (a2 == 0)] = 0
    out[(a1 == 1) & (a2 == 0)] = 1
    out[(a1 == -1) & (a2 == 0)] = 2
    out[(a1 == 0) & (a2 == 1)] = 3
    out[(a1 == 0) & (a2 == -1)] = 4
    out[(a1 == 1) & (a2 == 1)] = 5
    out[(a1 == -1) & (a2 == -1)] = 6
    out[(a1 == 1) & (a2 == -1)] = 7
    out[(a1 == -1) & (a2 == 1)] = 8
    return out


def clamp_time_to_step_time(time_value: float, cfg: "Config2D") -> float:
    step = int(round(float(time_value) / cfg.dt))
    step = max(0, min(cfg.n_steps - 1, step))
    return float(step * cfg.dt)


def unique_sorted_step_times(primary_time: float, extra_times: Tuple, cfg: "Config2D") -> Tuple:
    vals = [clamp_time_to_step_time(primary_time, cfg)]
    vals.extend(clamp_time_to_step_time(t, cfg) for t in extra_times)
    return tuple(sorted(set(vals)))


def compute_pmp_plane_pi_at_time(
    policy: PolicyNet2D,
    cfg: "Config2D",
    device: torch.device,
    time_value: float
) -> Dict:
    """Compute PMP plane in (pi1, pi2) = wealth-fraction coordinates."""
    pi1s = np.linspace(cfg.pi1_min, cfg.pi1_max, cfg.plane_points, dtype=np.float64)
    pi2s = np.linspace(cfg.pi2_min, cfg.pi2_max, cfg.plane_points, dtype=np.float64)
    PI1, PI2 = np.meshgrid(pi1s, pi2s)

    valid = _valid_pi_plane_mask(PI1, PI2, cfg)
    X, Y1, Y2 = pi_plane_to_xy(PI1, PI2, cfg)

    baseline_u1 = np.full_like(PI1, np.nan, dtype=np.float64)
    baseline_u2 = np.full_like(PI1, np.nan, dtype=np.float64)
    pmp_u1 = np.full_like(PI1, np.nan, dtype=np.float64)
    pmp_u2 = np.full_like(PI1, np.nan, dtype=np.float64)
    lam_x = np.full_like(PI1, np.nan, dtype=np.float64)
    lam_y1 = np.full_like(PI1, np.nan, dtype=np.float64)
    lam_y2 = np.full_like(PI1, np.nan, dtype=np.float64)
    buy_gap1 = np.full_like(PI1, np.nan, dtype=np.float64)
    sell_gap1 = np.full_like(PI1, np.nan, dtype=np.float64)
    buy_gap2 = np.full_like(PI1, np.nan, dtype=np.float64)
    sell_gap2 = np.full_like(PI1, np.nan, dtype=np.float64)
    trade_gap = np.full_like(PI1, np.nan, dtype=np.float64)
    trade_region = np.full(PI1.shape, -1, dtype=np.int64)
    pmp_region = np.full(PI1.shape, -1, dtype=np.int64)

    coords = np.argwhere(valid)
    if coords.size == 0:
        raise RuntimeError("No valid points in (pi1, pi2) plotting plane.")

    step = int(round(float(time_value) / cfg.dt))
    step = max(0, min(cfg.n_steps - 1, step))
    shared_noise = build_shared_noise_bank(step, cfg, device=device) if cfg.use_common_random_numbers else None

    for start in range(0, coords.shape[0], cfg.plane_chunk_size):
        chunk = coords[start:start + cfg.plane_chunk_size]
        j = chunk[:, 0]
        i = chunk[:, 1]

        x_t = torch.tensor(X[j, i], dtype=torch.float32, device=device)
        y_t = torch.tensor(np.stack([Y1[j, i], Y2[j, i]], axis=-1), dtype=torch.float32, device=device)
        t_frac = torch.full((x_t.numel(),), float(step) / cfg.n_steps, device=device)

        with torch.no_grad():
            base_u = policy_action_2d(policy, t_frac, x_t, y_t, cfg)

        pmp_u, lx, ly, bg, sg = pmp_projected_action_batch_2d(
            policy=policy,
            x=x_t,
            y=y_t,
            t_value=float(step * cfg.dt),
            cfg=cfg,
            device=device,
            noise_bank=shared_noise,
        )

        base_u_np = base_u.cpu().numpy()
        pmp_u_np = pmp_u.cpu().numpy()
        lx_np = lx.cpu().numpy()
        ly_np = ly.cpu().numpy()
        bg_np = bg.cpu().numpy()
        sg_np = sg.cpu().numpy()

        max_bg = np.maximum(bg_np[:, 0], bg_np[:, 1])
        max_sg = np.maximum(sg_np[:, 0], sg_np[:, 1])
        tg = np.maximum(max_bg, max_sg)

        lbl3 = np.full(base_u_np.shape[0], 1, dtype=np.int64)
        buy_mask = (max_bg > cfg.teacher_gap_tol) & (max_bg >= max_sg)
        sell_mask = (max_sg > cfg.teacher_gap_tol) & (max_sg > max_bg)
        lbl3[buy_mask] = 2
        lbl3[sell_mask] = 0

        lbl9 = classify_pmp_u_region(pmp_u_np[:, 0], pmp_u_np[:, 1], cfg.pmp_u_region_tol)

        baseline_u1[j, i] = base_u_np[:, 0]
        baseline_u2[j, i] = base_u_np[:, 1]
        pmp_u1[j, i] = pmp_u_np[:, 0]
        pmp_u2[j, i] = pmp_u_np[:, 1]
        lam_x[j, i] = lx_np
        lam_y1[j, i] = ly_np[:, 0]
        lam_y2[j, i] = ly_np[:, 1]
        buy_gap1[j, i] = bg_np[:, 0]
        sell_gap1[j, i] = sg_np[:, 0]
        buy_gap2[j, i] = bg_np[:, 1]
        sell_gap2[j, i] = sg_np[:, 1]
        trade_gap[j, i] = tg
        trade_region[j, i] = lbl3
        pmp_region[j, i] = lbl9

    return {
        "time": np.array([float(step * cfg.dt)], dtype=np.float64),
        "pi1_grid": PI1,
        "pi2_grid": PI2,
        "x_grid": X,
        "y1_grid": Y1,
        "y2_grid": Y2,
        "valid_mask": valid.astype(np.uint8),
        "baseline_u1": baseline_u1,
        "baseline_u2": baseline_u2,
        "pmp_u1": pmp_u1,
        "pmp_u2": pmp_u2,
        "lam_x": lam_x,
        "lam_y1": lam_y1,
        "lam_y2": lam_y2,
        "buy_gap1": buy_gap1,
        "sell_gap1": sell_gap1,
        "buy_gap2": buy_gap2,
        "sell_gap2": sell_gap2,
        "trade_gap": trade_gap,
        "trade_region": trade_region,
        "pmp_region": pmp_region,
    }


# ============================================================
# Classifier
# ============================================================

def train_region_classifier_multitime_pi(
    pmp_planes: List[Dict],
    cfg: "Config2D",
    device: torch.device
) -> Optional[RegionClassifier2D]:
    """
    Train a binary classifier for no-trade probability using PMP 9-region labels.

    Target:
        y = 1  iff  pmp_region == 0
        y = 0  otherwise

    This replaces the previous gap-based target:
        y = 1 iff trade_gap <= teacher_gap_tol
    """
    feats = []
    labels = []

    for plane in pmp_planes:
        PI1 = plane["pi1_grid"]
        PI2 = plane["pi2_grid"]
        valid = plane["valid_mask"].astype(bool)

        # PMP 9-region label:
        #   0 = No-trade
        #   1..8 = trade regions
        pmp_region = plane["pmp_region"].astype(np.int64)

        feat = classifier_features_pi(float(plane["time"][0]), PI1, PI2, cfg)

        y_notrade = (pmp_region == 0).astype(np.float64)

        feats.append(feat[valid])
        labels.append(y_notrade[valid])

    X_all = np.concatenate(feats, axis=0) if feats else np.empty((0, 3), dtype=np.float64)
    y_all = np.concatenate(labels, axis=0) if labels else np.empty((0,), dtype=np.float64)

    if X_all.shape[0] == 0:
        return None

    finite = np.isfinite(X_all).all(axis=1) & np.isfinite(y_all)
    X_all = X_all[finite]
    y_all = y_all[finite]

    if X_all.shape[0] == 0:
        return None

    # Class-balanced weights.
    pos_frac = float(np.clip(y_all.mean(), 1e-4, 1.0 - 1e-4))
    pos_w = (0.5 / pos_frac) ** cfg.cls_balance_power
    neg_w = (0.5 / (1.0 - pos_frac)) ** cfg.cls_balance_power
    w_all = np.where(y_all > 0.5, pos_w, neg_w).astype(np.float64)

    model = RegionClassifier2D(
        in_dim=3,
        hidden=cfg.cls_hidden,
        depth=cfg.cls_depth
    ).to(device)

    # Not used anymore, but keeping this attribute avoids breaking downstream code
    # if any diagnostic expects model.gap_scale to exist.
    model.gap_scale = None  # type: ignore[attr-defined]
    model.label_source = "pmp_region"  # type: ignore[attr-defined]

    opt = optim.Adam(
        model.parameters(),
        lr=cfg.cls_lr,
        weight_decay=cfg.cls_weight_decay
    )

    X_t = torch.tensor(X_all, dtype=torch.float32, device=device)
    y_t = torch.tensor(y_all, dtype=torch.float32, device=device)
    w_t = torch.tensor(w_all, dtype=torch.float32, device=device)

    n = X_t.shape[0]
    bs = min(int(cfg.cls_batch_size), n)

    for epoch in range(int(cfg.cls_epochs)):
        perm = torch.randperm(n, device=device)
        total_loss = 0.0
        total_acc = 0.0
        total_count = 0

        for start in range(0, n, bs):
            idx = perm[start:start + bs]
            xb = X_t[idx]
            yb = y_t[idx]
            wb = w_t[idx]

            logits = model(xb).squeeze(-1)

            loss_raw = nn.functional.binary_cross_entropy_with_logits(
                logits,
                yb,
                reduction="none"
            )
            loss = (loss_raw * wb).mean()

            opt.zero_grad(set_to_none=True)
            loss.backward()
            opt.step()

            with torch.no_grad():
                pred = (torch.sigmoid(logits) >= cfg.cls_prob_threshold).float()
                acc = (pred == yb).float().mean()

            batch_n = int(idx.numel())
            total_loss += float(loss.item()) * batch_n
            total_acc += float(acc.item()) * batch_n
            total_count += batch_n

        if (
            cfg.cls_print_every > 0
            and (
                epoch == 0
                or epoch == int(cfg.cls_epochs) - 1
                or (epoch + 1) % cfg.cls_print_every == 0
            )
        ):
            print(
                f"[classifier:pmp_region] "
                f"epoch={epoch+1:4d}/{cfg.cls_epochs} "
                f"loss={total_loss / max(total_count, 1):.6f} "
                f"acc={total_acc / max(total_count, 1):.4f} "
                f"pos_frac={pos_frac:.4f}"
            )

    return model


@torch.no_grad()
def predict_classifier_plane_pi_at_time(
    classifier: RegionClassifier2D,
    cfg: "Config2D",
    device: torch.device,
    time_value: float
) -> Dict:
    pi1s = np.linspace(cfg.pi1_min, cfg.pi1_max, cfg.cls_plane_points, dtype=np.float64)
    pi2s = np.linspace(cfg.pi2_min, cfg.pi2_max, cfg.cls_plane_points, dtype=np.float64)
    PI1, PI2 = np.meshgrid(pi1s, pi2s)
    valid = _valid_pi_plane_mask(PI1, PI2, cfg)
    pred_notrade = np.full(PI1.shape, -1, dtype=np.int64)
    prob_notrade = np.full(PI1.shape, np.nan, dtype=np.float64)

    coords = np.argwhere(valid)
    for start in range(0, coords.shape[0], cfg.plane_chunk_size):
        chunk = coords[start:start + cfg.plane_chunk_size]
        j = chunk[:, 0]
        i = chunk[:, 1]
        feat = classifier_features_pi(time_value, PI1[j, i], PI2[j, i], cfg)
        feat_t = torch.tensor(feat, dtype=torch.float32, device=device)
        logits = classifier(feat_t).squeeze(-1)
        temp = getattr(cfg, "cls_temperature", 5.0)
        probs = torch.sigmoid(logits / temp).cpu().numpy()
        prob_notrade[j, i] = probs
        pred_notrade[j, i] = (probs >= cfg.cls_prob_threshold).astype(np.int64)

    return {
        "time": np.array([time_value], dtype=np.float64),
        "pi1_grid": PI1,
        "pi2_grid": PI2,
        "valid_mask": valid.astype(np.uint8),
        "pred_notrade": pred_notrade,
        "prob_notrade": prob_notrade,
    }


# ============================================================
# PMP-u pseudo-flow (in wealth-fraction coords)
# ============================================================

def _bilinear_interp_nan_safe(
    xq: np.ndarray, yq: np.ndarray,
    x_grid_1d: np.ndarray, y_grid_1d: np.ndarray,
    value_grid: np.ndarray, valid_mask: np.ndarray,
) -> np.ndarray:
    out = np.full_like(xq, np.nan, dtype=np.float64)
    nx, ny = x_grid_1d.size, y_grid_1d.size
    ix = np.clip(np.searchsorted(x_grid_1d, xq, side="right") - 1, 0, nx - 2)
    iy = np.clip(np.searchsorted(y_grid_1d, yq, side="right") - 1, 0, ny - 2)
    tx = (xq - x_grid_1d[ix]) / np.maximum(x_grid_1d[ix+1] - x_grid_1d[ix], 1e-12)
    ty = (yq - y_grid_1d[iy]) / np.maximum(y_grid_1d[iy+1] - y_grid_1d[iy], 1e-12)
    v00 = value_grid[iy, ix]; v10 = value_grid[iy, ix+1]
    v01 = value_grid[iy+1, ix]; v11 = value_grid[iy+1, ix+1]
    m00 = valid_mask[iy, ix]; m10 = valid_mask[iy, ix+1]
    m01 = valid_mask[iy+1, ix]; m11 = valid_mask[iy+1, ix+1]
    good = m00 & m10 & m01 & m11
    val = ((1-tx)*(1-ty)*v00 + tx*(1-ty)*v10 + (1-tx)*ty*v01 + tx*ty*v11)
    out[good] = val[good]
    return out


def interpolate_pmp_u_field_pi(pmp_plane: Dict, pi1q: np.ndarray, pi2q: np.ndarray) -> Tuple[np.ndarray, np.ndarray]:
    PI1 = pmp_plane["pi1_grid"]
    PI2 = pmp_plane["pi2_grid"]
    valid = pmp_plane["valid_mask"].astype(bool)
    pi1_1d = PI1[0, :]
    pi2_1d = PI2[:, 0]
    v1 = _bilinear_interp_nan_safe(pi1q, pi2q, pi1_1d, pi2_1d, pmp_plane["pmp_u1"], valid)
    v2 = _bilinear_interp_nan_safe(pi1q, pi2q, pi1_1d, pi2_1d, pmp_plane["pmp_u2"], valid)
    return v1, v2


def valid_point_mask_pi(pi1: np.ndarray, pi2: np.ndarray, cfg: "Config2D") -> np.ndarray:
    return (
        np.isfinite(pi1) & np.isfinite(pi2)
        & (pi1 >= cfg.pi1_min) & (pi1 <= cfg.pi1_max)
        & (pi2 >= cfg.pi2_min) & (pi2 <= cfg.pi2_max)
        & (pi1 + pi2 < 0.999)
    )


def run_pmp_u_flow_on_plane_pi(pmp_plane: Dict, cfg: "Config2D") -> Dict:
    PI1 = pmp_plane["pi1_grid"]
    PI2 = pmp_plane["pi2_grid"]
    valid0 = pmp_plane["valid_mask"].astype(bool)

    start_pi1 = PI1[valid0].astype(np.float64).copy()
    start_pi2 = PI2[valid0].astype(np.float64).copy()
    cur_pi1 = start_pi1.copy()
    cur_pi2 = start_pi2.copy()

    alive = np.ones_like(cur_pi1, dtype=bool)
    stopped = np.zeros_like(cur_pi1, dtype=bool)
    n_alive_hist = []

    if len(cur_pi1) > 0:
        traj_idx = np.linspace(0, len(cur_pi1)-1, min(cfg.flow_traj_max_count, len(cur_pi1)), dtype=int)
        traj_pi1 = [cur_pi1[traj_idx].copy()]
        traj_pi2 = [cur_pi2[traj_idx].copy()]
    else:
        traj_idx = np.array([], dtype=int)
        traj_pi1, traj_pi2 = [], []

    for _ in range(cfg.flow_n_steps):
        if not np.any(alive):
            n_alive_hist.append(0)
            break
        v1, v2 = interpolate_pmp_u_field_pi(pmp_plane, cur_pi1, cur_pi2)
        bad = ~np.isfinite(v1) | ~np.isfinite(v2)
        alive[bad] = False
        speed = np.sqrt(np.nan_to_num(v1)**2 + np.nan_to_num(v2)**2)
        stop_now = np.isfinite(speed) & (speed < cfg.flow_stop_tol)
        stopped = stopped | stop_now
        step_v1 = np.tanh(cfg.flow_u_scale * np.nan_to_num(v1))
        step_v2 = np.tanh(cfg.flow_u_scale * np.nan_to_num(v2))
        move = alive & (~stop_now)
        cur_pi1[move] += cfg.flow_step_size * step_v1[move]
        cur_pi2[move] += cfg.flow_step_size * step_v2[move]
        alive = alive & valid_point_mask_pi(cur_pi1, cur_pi2, cfg)
        n_alive_hist.append(int(alive.sum()))
        if traj_idx.size > 0:
            traj_pi1.append(cur_pi1[traj_idx].copy())
            traj_pi2.append(cur_pi2[traj_idx].copy())

    ep_valid = valid_point_mask_pi(cur_pi1, cur_pi2, cfg)
    return {
        "start_pi1": start_pi1, "start_pi2": start_pi2,
        "end_pi1": cur_pi1, "end_pi2": cur_pi2,
        "endpoint_valid": ep_valid.astype(np.uint8),
        "stopped": stopped.astype(np.uint8),
        "alive_hist": np.array(n_alive_hist, dtype=np.int64),
        "traj_idx": traj_idx.astype(np.int64),
        "traj_pi1": np.array(traj_pi1, dtype=np.float64) if len(traj_pi1) > 0 else np.zeros((0,0)),
        "traj_pi2": np.array(traj_pi2, dtype=np.float64) if len(traj_pi2) > 0 else np.zeros((0,0)),
    }


