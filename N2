    txt.append("- Vertical axis   = y2 = X2/W  (asset 2 wealth fraction)")
    txt.append("- W = X0 + X1 + X2  (gross wealth)")
    txt.append("- y0 = X0/W = 1 - y1 - y2  (cash fraction)")
