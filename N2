# ============================================================
# Costate ratio heatmap: R_i = lambda_{y_i} / lambda_x
# ============================================================

def compute_costate_ratio(lam_x: np.ndarray, lam_y: np.ndarray, valid: np.ndarray, tol: float = 1e-10) -> Tuple[np.ndarray, np.ndarray]:
    """
    Compute R_i = lambda_{y_i} / lambda_x only where lambda_x is safely positive.
    Invalid points are set to NaN.

    In the proportional transaction-cost PMP condition:
        Buy if  R_i > 1
        NT if   1-alpha <= R_i <= 1
        Sell if R_i < 1-alpha
    """
    ratio = np.full_like(lam_x, np.nan, dtype=np.float64)
    valid_ratio = valid & np.isfinite(lam_x) & np.isfinite(lam_y) & (np.abs(lam_x) > tol)
    ratio[valid_ratio] = lam_y[valid_ratio] / lam_x[valid_ratio]
    return ratio, valid_ratio


def plot_costate_ratio_heatmap_pi(path: str, pmp_plane: Dict, cfg: "Config2D") -> None:
    """
    Plot asset-wise costate ratios:
        R_1 = lambda_{y1} / lambda_x
        R_2 = lambda_{y2} / lambda_x

    The no-trade wedge is:
        1 - alpha <= R_i <= 1.
    """
    PI1 = pmp_plane["pi1_grid"]
    PI2 = pmp_plane["pi2_grid"]
    valid = pmp_plane["valid_mask"].astype(bool)

    lam_x = pmp_plane["lam_x"]
    lam_y1 = pmp_plane["lam_y1"]
    lam_y2 = pmp_plane["lam_y2"]

    R1, valid_R1 = compute_costate_ratio(lam_x, lam_y1, valid)
    R2, valid_R2 = compute_costate_ratio(lam_x, lam_y2, valid)

    panels = [
        (R1, valid_R1, r"$R_1=\lambda_{y_1}/\lambda_x$"),
        (R2, valid_R2, r"$R_2=\lambda_{y_2}/\lambda_x$"),
    ]

    # Robust shared color scale around the no-trade wedge [1-alpha, 1].
    finite_all = []
    for R, valid_R, _ in panels:
        arr = np.where(valid_R, R, np.nan)
        finite = arr[np.isfinite(arr)]
        if finite.size > 0:
            finite_all.append(finite)

    if len(finite_all) > 0:
        finite_all = np.concatenate(finite_all)
        lo = np.nanpercentile(finite_all, 2)
        hi = np.nanpercentile(finite_all, 98)

        # Make sure the theoretical wedge boundaries are inside the displayed scale.
        lo = min(float(lo), 1.0 - cfg.alpha - 0.02)
        hi = max(float(hi), 1.0 + 0.02)
    else:
        lo, hi = 1.0 - cfg.alpha - 0.05, 1.0 + 0.05

    fig, axes = plt.subplots(
        1, 2,
        figsize=(NEURIPS_COLWIDTH_IN, 1.75),
        sharex=True,
        sharey=True
    )

    last_im = None
    for ax, (R, valid_R, title) in zip(axes, panels):
        arr = np.where(valid_R, R, np.nan)

        im = ax.pcolormesh(
            PI1, PI2, arr,
            cmap="viridis",
            shading="nearest",
            vmin=lo,
            vmax=hi,
            rasterized=True
        )

        # Theoretical transaction-cost wedge boundaries.
        ax.contour(
            PI1, PI2, arr,
            levels=[1.0 - cfg.alpha, 1.0],
            colors="k",
            linewidths=0.55,
            linestyles=["--", "-"]
        )

        style_axis_pi(ax, cfg, title="")
        last_im = im

    axes[0].set_xlabel(r"$y_1$")
    axes[1].set_xlabel(r"$y_1$")
    axes[0].set_ylabel(r"$y_2$")
    axes[1].set_ylabel(r"$y_2$")

    add_colorbar_compact(fig, last_im, axes.ravel().tolist())

    save_neurips_fig(fig, path)
    

